# ──────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/baalvion_invest?schema=public"
# Direct (non-pooled) URL for migrations when behind PgBouncer/RDS Proxy
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/baalvion_invest?schema=public"

# ──────────────────────────────────────────────────────────────
# Auth (JWT + MFA) — Phase 1 item 5
# ──────────────────────────────────────────────────────────────
JWT_ACCESS_PRIVATE_KEY=
JWT_ACCESS_PUBLIC_KEY=
JWT_ACCESS_TTL="900"          # seconds (15m)
JWT_REFRESH_TTL="604800"      # seconds (7d)
MFA_ISSUER="Baalvion Invest"
ENCRYPTION_KEY=               # 32-byte base64 — encrypts MFA secrets, doc keys

# ──────────────────────────────────────────────────────────────
# KYC / AML — Sumsub
# ──────────────────────────────────────────────────────────────
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL="https://api.sumsub.com"
SUMSUB_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
# Payments — Stripe + Wise
# ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WISE_API_TOKEN=
WISE_PROFILE_ID=
WISE_WEBHOOK_PUBLIC_KEY=

# ──────────────────────────────────────────────────────────────
# Storage — AWS S3
# ──────────────────────────────────────────────────────────────
AWS_REGION="eu-west-1"
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_DOCUMENT_BUCKET="baalvion-invest-documents"
S3_KMS_KEY_ID=

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="4000"
WEB_ORIGIN="http://localhost:3000"
