{
  "name": "@baalvion-invest/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, client and migrations for the Baalvion investment platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "format": "prisma format",
    "validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "argon2": "^0.41.1",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
