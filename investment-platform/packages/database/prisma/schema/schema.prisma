// ============================================================================
//  Baalvion Investment Platform — Prisma schema (root)
//  Multi-file schema (GA in Prisma 6.7+). Datasource + generator live here;
//  models are split by domain into sibling *.prisma files.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}
