// ============================================================================
//  Investor — profile, investment preferences, accreditation.
//  One InvestorProfile per investor Organization (1:1).
// ============================================================================

model InvestorProfile {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @unique @db.Uuid
  type         InvestorType
  thesis       String?
  aumBand      String? // e.g. "1M-10M", "100M+"
  website      String?
  contactEmail String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  preference     InvestmentPreference?
  accreditations Accreditation[]

  @@index([type])
}

model InvestmentPreference {
  id                String       @id @default(uuid()) @db.Uuid
  investorProfileId String       @unique @db.Uuid
  industries        String[]
  stages            String[]
  geographies       String[]
  ticketMin         Decimal?     @db.Decimal(20, 4)
  ticketMax         Decimal?     @db.Decimal(20, 4)
  currency          String       @default("USD") @db.VarChar(3)
  riskAppetite      RiskAppetite @default(MODERATE)
  updatedAt         DateTime     @updatedAt

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)
}

model Accreditation {
  id                  String              @id @default(uuid()) @db.Uuid
  investorProfileId   String              @db.Uuid
  method              AccreditationMethod
  status              AccreditationStatus @default(PENDING)
  jurisdiction        String              @db.VarChar(2) // ISO country of accreditation regime
  evidenceDocumentId  String?             @db.Uuid // -> Document
  reviewerUserId      String?             @db.Uuid
  verifiedAt          DateTime?
  expiresAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  investorProfile InvestorProfile @relation(fields: [investorProfileId], references: [id], onDelete: Cascade)

  @@index([investorProfileId])
  @@index([status])
}
