{
  "id": null,
  "uid": "baalvion-payments",
  "title": "Baalvion — Payments & Subscriptions",
  "description": "Razorpay and PayU payment metrics, webhook health, refund rates, subscription activations",
  "tags": ["baalvion", "payments", "razorpay", "payu"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Payments (24h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "increase(baalvion_payment_captured_total[24h])", "legendFormat": "Payments" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Revenue (24h, INR)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "increase(baalvion_payment_amount_total[24h])", "legendFormat": "Revenue" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyINR" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Webhook Failures (1h)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "increase(baalvion_payment_webhook_failures_total[1h])", "legendFormat": "Failures" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Subscriptions",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "baalvion_ctm_active_subscriptions_total", "legendFormat": "Active" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Payment Volume by Provider",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "sum(rate(baalvion_payment_captured_total[10m])) by (provider)",
          "legendFormat": "{{ provider }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cpm", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Payment Success vs Failure Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "rate(baalvion_payment_captured_total[10m])",
          "legendFormat": "Captured"
        },
        {
          "expr": "rate(baalvion_payment_failed_total[10m])",
          "legendFormat": "Failed"
        },
        {
          "expr": "rate(baalvion_payment_refunds_total[10m])",
          "legendFormat": "Refunded"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cpm" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Webhook Processing Latency",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(baalvion_payment_webhook_duration_ms_bucket[5m])) by (le, provider))",
          "legendFormat": "p95 {{ provider }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Subscription Activations & Cancellations",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        {
          "expr": "rate(baalvion_ctm_subscription_activations_total[30m])",
          "legendFormat": "Activations"
        },
        {
          "expr": "rate(baalvion_ctm_subscription_cancellations_total[30m])",
          "legendFormat": "Cancellations"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cpm" } }
    }
  ]
}
