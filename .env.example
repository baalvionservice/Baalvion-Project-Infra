# ─── JWT — RS256 is the ONE platform scheme (auth-service is the only issuer) ─
# auth-service signs access tokens RS256 (utils/jwtRsa.js). EVERY other service
# verifies with the SAME public key. Generate the dev keypair with:
#     node scripts/gen-dev-jwt-keys.mjs
# It writes docker/secrets/*.pem (gitignored) and fills JWT_PRIVATE_KEY /
# JWT_PUBLIC_KEY below as single-line, \n-escaped PEMs. In production, provision
# these from your secret store (Vault / external-secrets) — never commit keys.
JWT_PRIVATE_KEY=        # auth-service (+ proxy during migration) only — single-line PEM
JWT_PUBLIC_KEY=         # all services — single-line PEM (verifiers load this)
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_ALLOW_HS256_FALLBACK=false
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── REQUIRED secrets (Phase 1 hardening — NO fallback) ───────────────────────
# These are loaded via @baalvion/auth-node requireEnv(). A service REFUSES TO BOOT
# if its required secret is unset/empty — it will NOT silently use a default.
# Generate strong values: `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`
JWT_ACCESS_SECRET=        # REQUIRED by all token-verifying/issuing services (≥48 bytes)
JWT_REFRESH_SECRET=       # REQUIRED by auth-service, proxy-service, brand-connector-service
INTERNAL_SERVICE_SECRET=  # REQUIRED by session-service + notification-service (HMAC service-to-service auth)
# Keycloak confidential client secret (baalvion-os) — referenced by realm-baalvion.json + baalvion-os compose
KEYCLOAK_BAALVION_OS_SECRET=

# ─── PostgreSQL (shared across all services) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=baalvion_dev_pass

# ─── PostgreSQL TLS (in-transit) — PRODUCTION HARDENING ───────────────────────
# Node services derive TLS from @baalvion/auth-node buildPgSsl():
#   DB_SSL unset → TLS engages only when NODE_ENV=production; true|require|1|on
#   forces it on; false|0|disable|off forces it off (trusted private nets only).
#   Cert verification is ON unless DB_SSL_REJECT_UNAUTHORIZED=false. Pin the CA
#   with DB_SSL_CA (inline PEM) or DB_SSL_CA_PATH (file, preferred).
# DB_SSL=require
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA_PATH=/etc/ssl/rds-combined-ca-bundle.pem
#
# Java (financial-services-java) services append DB_JDBC_PARAMS VERBATIM to the
# JDBC URL. It is EMPTY by default (local dev). In any environment where the
# database enforces TLS (e.g. AWS RDS force_ssl=1), this MUST be set or every
# Java service is refused at connection time and never becomes ready.
#   Production example:  DB_JDBC_PARAMS=?sslmode=require
DB_JDBC_PARAMS=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── AWS / S3 (jobs-service file uploads) ────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=baalvion-uploads

# ─── S3-Compatible Storage ────────────────────────────────────────────────────
S3_REGION=us-east-1
S3_BUCKET=baalvion-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=              # Leave blank for AWS S3; set for MinIO/R2/Cloudflare

# ─── Upload malware scanning (@baalvion/upload) — PRODUCTION HARDENING ────────
# Media-accepting services (cms-service, commerce-service, law-service) validate
# uploads by magic bytes and route the raw bytes through a pluggable scanner.
#   UPLOAD_SCAN_URL  — HTTP scan endpoint. The bytes are POSTed and a JSON
#                      { "clean": boolean, "reason"?: string } verdict expected
#                      (fail-closed on transport/parse error). Point this at a
#                      ClamAV-over-HTTP gateway, AV API, or scan microservice.
#   UPLOAD_SCAN_REQUIRED — defaults to "true" in production. If true and no
#                      UPLOAD_SCAN_URL is wired, those services FAIL CLOSED and
#                      return 503 on upload. Set to "false" to explicitly opt out
#                      (uploads then accepted with magic-byte validation only).
#   UPLOAD_SCAN_TIMEOUT_MS — scanner request timeout (default 8000).
UPLOAD_SCAN_URL=
UPLOAD_SCAN_REQUIRED=false
# UPLOAD_SCAN_TIMEOUT_MS=8000

# ─── Razorpay (proxy backend) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── PayU (proxy backend) ─────────────────────────────────────────────────────
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://secure.payu.in/_payment

# ─── Amazon SES (PRIMARY email provider — @baalvion/email) ────────────────────
# Production email is sent via Amazon SES (AWS SDK v3) through the centralized
# @baalvion/email package. Every backend that sends mail (auth, notification, proxy,
# law, jobs, admin) uses it; order/payment mail flows through notification-service.
#
# Credentials come from the baalvion-ses-smtp IAM user (ses:SendEmail/ses:SendRawEmail)
# — NEVER commit them. On EC2/ECS you may instead rely on the instance/task role by
# setting SES_USE_INSTANCE_ROLE=true and leaving the keys blank.
#
# AWS_REGION / AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are declared once above
# (AWS / S3 block). SES reuses them. Region must be ap-south-1 (where the domain is verified).
SES_CONFIGURATION_SET=baalvion-production
# SES_USE_INSTANCE_ROLE=false        # true → use ambient IAM role, no static keys
# Verified senders (one per purpose — keeps sender reputation partitioned):
SES_FROM_AUTH=noreply@baalvion.com           # OTP, verification, password reset, welcome
SES_FROM_NOTIFICATIONS=notifications@baalvion.com  # order confirmations, newsletters
SES_FROM_SECURITY=security@baalvion.com      # login / security alerts
SES_FROM_SUPPORT=support@baalvion.com        # support replies (Zoho distribution group)
SES_FROM_BILLING=billing@baalvion.com        # invoices (Zoho distribution group)
SES_FROM_INVREL=invrel@baalvion.com          # investor-relations mail
SES_FROM_NAME=Baalvion
EMAIL_REPLY_TO=support@baalvion.com
# Retry tuning (transient failures only; hard bounces are never retried):
# SES_MAX_ATTEMPTS=3
# SES_RETRY_BASE_MS=500
# SES_RETRY_MAX_MS=8000
# SNS → SES delivery-event webhook (notification-service POST /webhooks/aws/ses).
# Leave unset in prod (signature verification ON). Set to "false" ONLY for local testing.
# SES_WEBHOOK_VERIFY=true

# ─── SMTP / Email (FALLBACK only — used when SES is not configured) ────────────
# Kept for local dev (point at Mailpit :1025) and as a failover transport. To use
# SES over SMTP instead of the SDK, set SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# with the SES *SMTP* username/password (NOT the IAM access keys).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@baalvion.com
# RESEND_API_KEY=                    # optional secondary fallback (notification-service)

# ─── Auth Service — RS256 key file alternative (instead of inline JWT_PUBLIC_KEY) ─
# Optional: set these INSTEAD of the inline JWT_PRIVATE_KEY/JWT_PUBLIC_KEY above
# if you mount PEM files (auth-service vault.js + oauth/admin/session read *_PATH first).
# Do NOT re-declare JWT_ISSUER/JWT_AUDIENCE here — they are set once, above.
# JWT_PRIVATE_KEY_PATH=./docker/secrets/jwt_private_key.pem
# JWT_PUBLIC_KEY_PATH=./docker/secrets/jwt_public_key.pem

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_JOBS=baalvion_jobs

# ─── OpenSearch / Elasticsearch ───────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASS=

# ─── Frontend URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_AUTH_URL=http://localhost:3001/v1/auth
NEXT_PUBLIC_REALTIME_URL=http://localhost:3040
NODE_ENV=development

# ─── Dev tooling credentials (cleanup/infra-hardening) ────────────────────────
# These tools are now profile-gated + loopback-bound. Override the placeholder
# passwords before starting them. pgAdmin:  docker compose --profile tools up -d pgadmin
PGADMIN_DEFAULT_EMAIL=admin@baalvion.com
PGADMIN_DEFAULT_PASSWORD=change-me-in-env
# Keycloak only backs the experimental baalvion-os subsystem (profile: baalvion-os).
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-env
# Grafana admin (observability stack).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-env
