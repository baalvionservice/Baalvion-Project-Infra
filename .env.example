# ─── Shared JWT Secrets (HS256 — all domain services) ────────────────────────
JWT_ACCESS_SECRET=replace-with-min-64-char-random-secret
JWT_REFRESH_SECRET=replace-with-min-64-char-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── PostgreSQL (shared across all services) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=baalvion_dev_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── AWS / S3 (jobs-service file uploads) ────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=baalvion-uploads

# ─── S3-Compatible Storage ────────────────────────────────────────────────────
S3_REGION=us-east-1
S3_BUCKET=baalvion-assets
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=              # Leave blank for AWS S3; set for MinIO/R2/Cloudflare

# ─── Razorpay (proxy backend) ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── PayU (proxy backend) ─────────────────────────────────────────────────────
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://secure.payu.in/_payment

# ─── SMTP / Email ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@baalvion.com

# ─── Auth Service (RS256 key paths — for identity services) ──────────────────
JWT_PRIVATE_KEY_PATH=./docker/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=./docker/secrets/jwt_public_key.pem
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_JOBS=baalvion_jobs

# ─── OpenSearch / Elasticsearch ───────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASS=

# ─── Frontend URLs ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_AUTH_URL=http://localhost:3001/v1/auth
NEXT_PUBLIC_REALTIME_URL=http://localhost:3040
NODE_ENV=development
