{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "Services Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [ { "expr": "sum(baalvion_service_up)", "refId": "A" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } } }
    },
    {
      "type": "stat",
      "title": "Active Sessions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [ { "expr": "baalvion_active_sessions", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Logins (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [ { "expr": "baalvion_logins_24h", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Realtime WS Clients",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [ { "expr": "baalvion_ws_clients", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Host CPU / Memory / Disk (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        { "expr": "baalvion_cpu_percent", "legendFormat": "CPU", "refId": "A" },
        { "expr": "baalvion_memory_percent", "legendFormat": "Memory", "refId": "B" },
        { "expr": "baalvion_disk_percent", "legendFormat": "Disk", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Service Health-Probe Latency (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [ { "expr": "baalvion_service_latency_ms", "legendFormat": "{{service}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Datastores",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "baalvion_postgres_connections", "legendFormat": "PG connections", "refId": "A" },
        { "expr": "baalvion_redis_clients", "legendFormat": "Redis clients", "refId": "B" },
        { "expr": "baalvion_redis_keys", "legendFormat": "Redis keys", "refId": "C" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue Failures",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [ { "expr": "sum(baalvion_queue_failed)", "legendFormat": "failed jobs", "refId": "A" } ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [ "baalvion" ],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "title": "Baalvion Platform Overview",
  "uid": "baalvion-platform",
  "version": 1
}
