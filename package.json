{
  "name": "baalvion-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Baalvion Identity Platform — enterprise monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "build:all": "powershell -ExecutionPolicy Bypass -File ./scripts/build-all.ps1",
    "build:packages": "turbo run build --filter='./Backend/packages/*'",
    "dev": "turbo run dev --filter='./Backend/*' --filter='./Backend/services/*/*' --filter='./Frontend/*'",
    "dev:identity": "turbo run dev --filter='{./Backend/auth-service,./Backend/admin-service,./Backend/session-service,./Backend/oauth-service,./Frontend/admin-platform}'",
    "dev:backends": "turbo run dev --filter='./Backend/*' --filter='./Backend/services/*/*'",
    "dev:frontends": "turbo run dev --filter='./Frontend/*'",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "lighthouse": "lhci autorun",
    "test:packages": "turbo run test --filter='./Backend/packages/*'",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "ci:auth:jwt-imports": "node scripts/ci/check-jwt-imports.mjs Backend",
    "ci:auth:localstorage": "node scripts/ci/check-localstorage-auth.mjs Frontend",
    "ci:auth:algorithms": "node scripts/ci/check-jwt-algorithms.mjs Backend",
    "ci:auth:middleware": "node scripts/ci/check-auth-middleware.mjs Backend/services",
    "ci:auth:guards": "npm run ci:auth:jwt-imports && npm run ci:auth:localstorage && npm run ci:auth:algorithms && npm run ci:auth:middleware",
    "ci:rls:audit": "node Backend/scripts/tenant-isolation-audit.mjs",
    "ci:rls:test": "node --test Backend/scripts/tenant-isolation-audit.test.mjs Backend/packages/tenancy/test.smoke.js",
    "ci:rls": "npm run ci:rls:audit && npm run ci:rls:test",
    "clean": "turbo run clean && rimraf node_modules",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres redis",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis",
    "infra:up": "docker compose up -d postgres redis pgadmin",
    "infra:down": "docker compose down",
    "migrate": "turbo run migrate --filter='./Backend/*' --filter='./Backend/services/*/*'",
    "migrate:auth": "cd Backend/services/identity/auth-service && npm run migrate",
    "generate:keys": "cd Backend/services/identity/auth-service && npm run generate-keys",
    "generate:api": "turbo run generate:api",
    "catalog:validate": "node Backend/catalog/validate.mjs",
    "catalog:enforce": "node Backend/catalog/enforce.mjs",
    "architecture:check": "node Backend/catalog/validate.mjs && node Backend/catalog/enforce.mjs",
    "catalog:list": "node Backend/platform/cli/baalctl.mjs catalog list",
    "contracts:lint": "cd Backend/packages/contracts && buf lint",
    "contracts:events": "node Backend/packages/contracts/scripts/validate-events.mjs",
    "baalctl": "node Backend/platform/cli/baalctl.mjs",
    "scan:errors": "node scripts/error-scan.mjs"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.48.0",
    "@types/jest": "^29.5.0",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.0",
    "turbo": "^2.9.16",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.29",
      "@types/react-dom": "18.3.7",
      "next": "15.5.18",
      "handlebars": "4.7.9",
      "protobufjs": "7.6.1",
      "@protobufjs/utf8": "1.1.1",
      "fast-uri": "3.1.2",
      "follow-redirects": "1.16.0",
      "node-forge": "1.4.0",
      "lodash": "4.18.0",
      "axios": "1.16.0",
      "postcss": "8.5.10",
      "qs": "6.15.2",
      "tmp": "0.2.7",
      "js-yaml": "4.1.1",
      "yaml": "2.8.3",
      "prismjs": "1.30.0",
      "d3-color": "3.1.0",
      "@tootallnate/once": "2.0.1",
      "webpack": "5.104.1",
      "fast-xml-builder": "1.1.7",
      "fast-xml-parser@4": "4.5.5",
      "brace-expansion@1": "1.1.12",
      "brace-expansion@2": "2.0.3",
      "minimatch@3": "3.1.4",
      "minimatch@9": "9.0.7",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "path-to-regexp@<0.1.13": "0.1.13",
      "ajv@8": "8.18.0",
      "nodemailer": "8.0.11",
      "dompurify@3": "3.4.0",
      "tar@7": "7.5.11",
      "form-data@4": "4.0.6",
      "form-data@2": "2.5.6",
      "vite@7": "7.3.5",
      "vite@6": "6.4.3",
      "ws": "8.21.0",
      "glob@10": "10.5.0",
      "file-type@21": "21.3.2",
      "@modelcontextprotocol/sdk": "1.26.0",
      "ip-address": "10.1.1",
      "uuid@11": "11.1.1",
      "esbuild": "0.28.1"
    }
  }
}
