# ─────────────────────────────────────────────────────────────────────────────
# Production secrets for the About-Baalvion CMS stack (single EC2 + Docker Compose).
# Copy to `.env.prod` and fill every __CHANGE_ME__. NEVER commit the real .env.prod.
#
#   cp deploy/about-baalvion-cms/.env.prod.example deploy/about-baalvion-cms/.env.prod
#   nano deploy/about-baalvion-cms/.env.prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains + TLS (Caddy / Let's Encrypt) ───────────────────────────────────
# Public host for the CMS delivery + admin API. This is what Vercel's CMS_PUBLIC_URL points at.
DOMAIN_CMS=cms.baalvion.com
# Public host for the admin console (only used when you run `--profile admin`).
DOMAIN_ADMIN=admin.baalvion.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=__CHANGE_ME__

# ── PostgreSQL (internal to the compose network; never published) ────────────
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__
# Services default to REQUIRING DB TLS in production (correct for RDS). The in-network
# Postgres container has no TLS, so keep this false. Set to true (or remove) only when you
# move DB_HOST to RDS / a TLS-enabled Postgres.
DB_SSL=false

# ── Redis (internal) ─────────────────────────────────────────────────────────
# No password needed on the internal network; add one if you publish Redis.

# ── RS256 signing keypair (auth-service MINTS tokens; cms-service VERIFIES) ───
# Generate: cd Backend/services/identity/auth-service && npm run generate-keys
# Then single-line, \n-escape each PEM:
#   awk 'NF {printf "%s\\n", $0}' keys/private.pem   # -> JWT_PRIVATE_KEY
#   awk 'NF {printf "%s\\n", $0}' keys/public.pem    # -> JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=__CHANGE_ME__
JWT_PUBLIC_KEY=__CHANGE_ME__
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── cms-service production guards (it REFUSES to start without these) ─────────
# Inter-service secret + the key used to encrypt the per-tenant provider vault.
#   openssl rand -hex 32   (run twice, different values)
INTERNAL_SERVICE_SECRET=__CHANGE_ME__
CMS_SECRETS_KEY=__CHANGE_ME__

# ── Super-admin (used to bootstrap the login + to authenticate the seed) ──────
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=__CHANGE_ME__

# ── CORS: origins allowed to call the CMS admin API from a browser ────────────
# The PUBLIC delivery API (what Vercel reads server-side) is not subject to CORS.
# Include the prod admin console + your LOCAL admin-platform if you manage content
# locally against this prod CMS.
CORS_ORIGINS=https://admin.baalvion.com,http://localhost:3030,http://localhost:5173

# ── auth-gateway BFF (only used with `--profile admin`) ───────────────────────
#   openssl rand -hex 32
GATEWAY_SIGNING_SECRET=__CHANGE_ME__

# ── Transactional email (optional; password reset + member invites) ───────────
EMAIL_FROM=noreply@baalvion.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
