# ─────────────────────────────────────────────────────────────────────────────
# Baalvion single-host EC2 backend — environment.
#   cp .env.production.example .env.production   then fill every 🔒 value.
# Generate secrets:  openssl rand -hex 32   /   openssl rand -base64 48
# RS256 platform keypair:  pnpm run generate:keys  (then single-line the PEMs, see runbook §3).
# NEVER commit .env.production (see .gitignore in this folder).
# ─────────────────────────────────────────────────────────────────────────────

# ── Images / ingress ─────────────────────────────────────────────────────────
IMAGE_PREFIX=baalvion          # or <ACCOUNT_ID>.dkr.ecr.ap-south-1.amazonaws.com/baalvion
IMAGE_TAG=prod-latest
ACME_EMAIL=infra.baalvion@gmail.com

# ── Data tier (self-contained: local postgres/redis/redpanda) ────────────────
DB_USER=baalvion
DB_PASSWORD=                   # 🔒 superuser/owner + migration role. Use URL-SAFE chars: it is
                               #    embedded in GTI's DATABASE_URL (postgresql://user:PASS@…). If it
                               #    must contain @ : / ? # — URL-encode it there.
DB_NAME=baalvion_db
CTM_DB=ctm_db
PROXY_DB=proxy_db
GTI_DB=gti_db                  # trade.baalvion.com (GTI) Prisma orchestration store
DB_APP_USER=baalvion_app
DB_APP_PASSWORD=               # 🔒 Stack A payment-service RLS runtime role
DB_SSL=disable                 # local Postgres has NO TLS — do NOT set require here
DB_JDBC_PARAMS=                # leave EMPTY (no sslmode=require) for the local DB
REDIS_PASSWORD=                # empty for the in-compose redis

# ════════════════════════════ Stack A — platform ════════════════════════════
# RS256 keypair (single-line PEMs with literal \n). Public half is shared to B & C for SSO.
JWT_PRIVATE_KEY=               # 🔒
JWT_PUBLIC_KEY=                # 🔒
JWT_ACCESS_SECRET=             # 🔒 openssl rand -base64 48
JWT_REFRESH_SECRET=            # 🔒 openssl rand -base64 48
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
API_BASE_URL=https://api.baalvion.com
# Browser origins allowed to call api.baalvion.com (the Vercel frontends) + the gateway /auth
# used by trade.baalvion.com (same-origin via the edge). Stack D frontends included.
CORS_ORIGINS=https://admin.baalvion.com,https://baalvion.com,https://www.baalvion.com,https://about.baalvion.com,https://amarisemaisonavenue.com,https://lawelitenetwork.com,https://imperialpedia.com,https://trade.baalvion.com

SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=           # 🔒 rotate after first login
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=                     # 🔒 SES SMTP user
SMTP_PASS=                     # 🔒 SES SMTP pass
EMAIL_FROM=noreply@baalvion.com

INTERNAL_SERVICE_SECRET=       # 🔒 openssl rand -hex 32
GATEWAY_SIGNING_SECRET=        # 🔒 openssl rand -hex 32
RBAC_INTERNAL_API_KEY=         # 🔒 openssl rand -hex 32
AUDIT_INTERNAL_KEY=            # 🔒 openssl rand -hex 32
INVENTORY_INTERNAL_KEY=        # 🔒 openssl rand -hex 32
CART_SESSION_SECRET=           # 🔒 openssl rand -hex 32
CMS_SECRETS_KEY=               # 🔒 openssl rand -hex 32
CMS_BASE_URL=http://cms-service:3018
AMARISE_CMS_SLUG=amarise-maison-avenue

# Razorpay LIVE (storefront order-service + Stack A Java payment-service)
RAZORPAY_KEY_ID=               # 🔒 rzp_live_...
RAZORPAY_KEY_SECRET=           # 🔒
RAZORPAY_WEBHOOK_SECRET=       # 🔒
RAZORPAY_BASE_URL=https://api.razorpay.com

# ── Trade / GTI (trade.baalvion.com) consumer gateway checkout ────────────────
# PRIMARY path = the central CMS vault: paste LIVE Razorpay / Cashfree / PayU keys in the admin panel
# (admin.baalvion.com → website TRADE_PAYMENT_SITE_SLUG → Integrations & Keys); trade-service reads
# them via CMS_BASE_URL + INTERNAL_SERVICE_SECRET and uses them within ~60s, no redeploy. The keys
# below are an optional FALLBACK. TRADE_PAYMENT_SITE_SLUG must equal the website's registered CMS slug.
TRADE_PAYMENT_SITE_SLUG=       # e.g. global-trade-infrastructure (the trade.baalvion.com CMS slug)
TRADE_STOREFRONT_URL=https://trade.baalvion.com
TRADE_CASHFREE_CLIENT_ID=      # 🔒 (fallback only — prefer the vault)
TRADE_CASHFREE_CLIENT_SECRET=  # 🔒
TRADE_CASHFREE_MODE=live
TRADE_PAYU_MERCHANT_KEY=       # 🔒
TRADE_PAYU_MERCHANT_SALT=      # 🔒
TRADE_PAYU_RETURN_URL=         # public URL PayU posts surl/furl to (routes to trade-service /orders/webhooks/payu)

# Object storage (optional — leave blank to disable media upload; content APIs still serve)
AWS_REGION=ap-south-1
MEDIA_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=                 # 🔒
S3_SECRET_KEY=                 # 🔒
S3_PUBLIC_URL=

# ════════════════════════════ Stack B — ControlTheMarket ════════════════════
CTM_CORS_ORIGINS=https://controlthemarket.com
# Payments PRIMARY path = the central CMS vault: paste LIVE Razorpay/Cashfree/PayU keys in the admin
# panel (admin.baalvion.com → website CTM_PAYMENT_SITE_SLUG → Integrations & Keys); ctm-service reads
# them via CTM_CMS_BASE_URL + INTERNAL_SERVICE_SECRET and uses them within ~60s, no redeploy. The CTM_*
# keys below are an optional FALLBACK. (CTM_CMS_BASE_URL must end in /api/v1 — ctm-service appends
# /internal/integrations to it.)
CTM_PAYMENT_SITE_SLUG=control-the-market
CTM_CMS_BASE_URL=http://cms-service:3018/api/v1
CTM_PAYMENT_PROVIDER=razorpay
CTM_RAZORPAY_KEY_ID=           # 🔒 rzp_live_... (fallback only — prefer the vault)
CTM_RAZORPAY_KEY_SECRET=       # 🔒
CTM_RAZORPAY_WEBHOOK_SECRET=   # 🔒
CTM_CASHFREE_CLIENT_ID=        # 🔒 (fallback only — prefer the vault)
CTM_CASHFREE_CLIENT_SECRET=    # 🔒
CTM_PAYU_MERCHANT_KEY=         # 🔒
CTM_PAYU_MERCHANT_SALT=        # 🔒
CTM_PAYMENT_SUCCESS_URL=https://controlthemarket.com/billing/success
CTM_PAYMENT_CANCEL_URL=https://controlthemarket.com/billing/cancel

# ════════════════════════════ Stack C — Proxy / BaalvionStack ════════════════
# proxy-service signs its OWN customer tokens with an RS256 keypair mounted at
# ./secrets/keys/<kid>.key|.pub  (generate per runbook §3). CMS_JWT_PUBLIC_KEY is that
# public half, reused by proxy-cms-service (it requires a public key at boot).
PROXY_JWT_ACCESS_SECRET=       # 🔒 openssl rand -base64 48
PROXY_JWT_REFRESH_SECRET=      # 🔒 openssl rand -base64 48
PROXY_JWT_ACTIVE_KID=baalvion-key-1
CMS_JWT_PUBLIC_KEY=            # 🔒 proxy RS256 public PEM, single-line
PROXY_CMS_SECRETS_KEY=         # 🔒 openssl rand -hex 32
PROXY_INTERNAL_SERVICE_SECRET= # 🔒 openssl rand -hex 32
PROXY_PAYMENT_SITE_SLUG=proxy-baalvionstack
PROXY_PUBLIC_APP_URL=https://baalvionstack.com
PROXY_CORS_ORIGINS=https://baalvionstack.com
PROXY_CMS_CORS_ORIGINS=https://baalvionstack.com,https://about.baalvion.com
PROXY_RAZORPAY_KEY_ID=         # 🔒 rzp_live_...
PROXY_RAZORPAY_KEY_SECRET=     # 🔒
PROXY_RAZORPAY_WEBHOOK_SECRET= # 🔒

# ════════════════════════════ Stack D — Law / Imperialpedia / Trade ══════════════
# These reuse Stack A's RS256 keypair (JWT_PUBLIC_KEY) + JWT_ACCESS_SECRET + GATEWAY_SIGNING_SECRET
# for central SSO — no new auth keys. Only the per-app knobs below are app-specific.

# ── Law Elite Network (lawelitenetwork.com) — law-service, baalvion_db/schema legal ──
# Editorial content comes from Stack A cms-service (register+seed the `law-elite-network`
# website — see VALIDATION-RUNBOOK §10). law-service powers directory/bookings/cases/billing.
LAW_CORS_ORIGINS=https://lawelitenetwork.com
LAW_PUBLIC_URL=https://lawelitenetwork.com
LAW_ADMIN_EMAILS=infra.baalvion@gmail.com
LAW_BILLING_WORKER_ENABLED=true
LAW_MAIL_ENABLED=false               # set true only once SMTP_* (above) is a verified sender
LAW_MAIL_FROM=Law Elite Network <no-reply@lawelitenetwork.com>
LAW_S3_BUCKET=                       # optional — blank disables document upload
# Razorpay for law subscriptions (optional — blank → simulated until provided)
LAW_RAZORPAY_KEY_ID=                 # 🔒 rzp_live_...
LAW_RAZORPAY_KEY_SECRET=             # 🔒
LAW_RAZORPAY_WEBHOOK_SECRET=         # 🔒

# ── Imperialpedia (imperialpedia.com) — imperialpedia-service, baalvion_db/schema imperialpedia ──
# Editorial articles come from Stack A cms-service (register+seed the `imperialpedia` website).
# imperialpedia-service serves the structured entities (companies/countries/industries/glossary).
IMPERIALPEDIA_CORS_ORIGINS=https://imperialpedia.com

# ── Trade (trade.baalvion.com) — GTI full-stack app + trade-service data tier ─────
# gti-web build args (NEXT_PUBLIC_* are baked at image build); also the public site URL.
TRADE_PUBLIC_URL=https://trade.baalvion.com
TRADE_CORS_ORIGINS=https://trade.baalvion.com
# Firebase Admin SDK (OPTIONAL — a feature subset; trade-service boots without it). If used,
# single-line the private key with literal \n. Leave blank to run without Firebase features.
TRADE_FIREBASE_PROJECT_ID=
TRADE_FIREBASE_CLIENT_EMAIL=
TRADE_FIREBASE_PRIVATE_KEY=
