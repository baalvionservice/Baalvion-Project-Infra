# ir-stack production env template. Copy to deploy/ir-stack/.env.prod and fill in.
# NEVER commit the real .env.prod (it is gitignored below). Secrets are injected at deploy time.

# ── Public domain (point an A record at this host BEFORE first boot for TLS) ──
DOMAIN_IR_API=ir-api.baalvion.com
ACME_EMAIL=ops@baalvion.com

# ── Postgres (slice-local) ──
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DB_SSL=false

# ── Auth (ir-service VERIFIES tokens only — provide the PUBLIC key, \n-escaped on one line) ──
# Generate alongside auth-service's keypair; this MUST be the public half of the issuer's key.
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
# Alternatively (or additionally) verify via JWKS instead of a static key:
# BAALVION_JWKS_URI=https://api.baalvion.com/.well-known/jwks.json

# ── IR app behaviour ──
CORS_ORIGINS=https://ir.baalvion.com
# Must match the IR org id used by staff tooling / the admin console that reviews applications.
IR_DEFAULT_ORG_ID=11111111-1111-1111-1111-111111111111
IR_DEAL_ROOM_COOLDOWN_MINUTES=5
RATE_LIMIT_IP_MAX=120

# ── Image registry (only needed when pulling prebuilt images instead of --build) ──
# IMAGE_PREFIX=869657603174.dkr.ecr.ap-south-1.amazonaws.com/baalvion
# IMAGE_TAG=prod-latest
