# ─────────────────────────────────────────────────────────────────────────────
# Production environment for the Company Unified Dashboard (single-EC2 Docker Compose).
# Copy to `.env.prod` on the server and fill EVERY __CHANGE_ME__. NEVER commit `.env.prod`.
# Generate strong random secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Container images (GHCR) — only used if you pull pre-built images via CI ────
IMAGE_PREFIX=ghcr.io/baalvionservice/baalvion
IMAGE_TAG=prod-latest

# ── Domain + TLS ──────────────────────────────────────────────────────────────
DOMAIN=dashboard.baalvion.com
ACME_EMAIL=ops@baalvion.com

# ── Postgres (in-compose; swap to RDS by pointing DB_HOST at the RDS endpoint) ─
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
# Leave these as the compose service name unless you move to RDS.
DB_HOST=postgres
DB_PORT=5432
# ── Database TLS (REQUIRED when DB_HOST points at RDS / any non-localhost Postgres) ──
# In-compose Postgres on the same host has no TLS → DB_SSL=false. For RDS set DB_SSL=true,
# keep cert verification on, and pin the RDS CA bundle.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=<paste RDS CA bundle PEM, single line with \n escapes>
# ── RLS cutover (see Backend/docs/RLS-PRODUCTION-CUTOVER.md) ──
# Services connect as the owner role, which BYPASSES Postgres RLS. After verifying tenant
# isolation per service, point DB_USER at the non-superuser baalvion_app role so RLS enforces.
# Run migrations as POSTGRES_USER (owner) — they must bypass RLS.
# DB_USER=baalvion_app
# DB_PASSWORD=__CHANGE_ME__baalvion_app_password__
REDIS_HOST=redis
REDIS_PORT=6379

# ── App config ────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── RS256 signing keypair — auth-service MINTS access/refresh tokens with this ──
# Generate locally (NOT on the box if you can avoid it), then paste as SINGLE-LINE \n-escaped PEM:
#   cd Backend/services/identity/auth-service && npm run generate-keys     # writes keys/*.pem
#   awk 'NF {printf "%s\\n", $0}' keys/private.pem   # → paste as JWT_PRIVATE_KEY
#   awk 'NF {printf "%s\\n", $0}' keys/public.pem    # → paste as JWT_PUBLIC_KEY
# Every other service VERIFIES with the PUBLIC half (or via the gateway's JWKS_URI to auth-service).
JWT_PRIVATE_KEY=__CHANGE_ME__single_line_rs256_private_pem__
JWT_PUBLIC_KEY=__CHANGE_ME__single_line_rs256_public_pem__
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── HS fallback secrets — required present at boot even with RS256 (fail-closed) ─
JWT_ACCESS_SECRET=__CHANGE_ME__openssl_rand_hex_32__
JWT_REFRESH_SECRET=__CHANGE_ME__openssl_rand_hex_32__

# ── Gateway trust + inter-service ──────────────────────────────────────────────
# The gateway signs identity headers with this; min 32 chars. (dashboard-service does NOT get it —
# it uses the forwarded Bearer instead — see the compose comment.)
GATEWAY_SIGNING_SECRET=__CHANGE_ME__openssl_rand_hex_32__
# session-service ↔ internal callers.
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__

# ── Optional: realtime live updates (realtime-service is NOT in this slice) ─────
# Leave blank. If you later add realtime-service, set this to wss://${DOMAIN}/<path> and open the
# CSP connect-src in the dashboard next.config.
NEXT_PUBLIC_REALTIME_WS_URL=

# ── Optional: transactional email (password reset, invites). Blank = logged, not sent ─
EMAIL_FROM=noreply@baalvion.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Bootstrap the platform super-admin AFTER first boot (see DEPLOY-AWS.md §6) ──
# Used only by the one-off bootstrap command, not by the running services.
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=__CHANGE_ME__your_admin_login_password__
