# ─────────────────────────────────────────────────────────────────────────────
# Edge: TLS termination + host/path routing to the app containers. Only Caddy binds
# 80/443; every app + Redis stay internal to the compose network. Caddy auto-upgrades
# websockets, so socket.io / realtime work through reverse_proxy unchanged.
#
# Routing targets are <app-container>:<service-port>. Because each app container has its
# own network IP, the same port can appear in two apps without colliding.
#
# Internal service-to-service calls do NOT go through Caddy — they use Docker DNS directly
# (e.g. http://app-commerce:3013, http://app-platform:3018), exactly as before.
# ─────────────────────────────────────────────────────────────────────────────
{
	email ops@baalvion.com
}

# ── Central auth surface → identity app (auth-gateway) ──
auth.baalvion.com {
	encode gzip zstd
	reverse_proxy app-identity:3026
}

# ── Consumer + admin BFF → edge-realtime app (proxy-service) ──
# The session-gated BFF answers /api/* by default, but two surfaces MUST be reachable without a
# session for the public Vercel sites to work — public CMS delivery and the PSP webhook/initiate
# surface. These carve-outs are matched first; everything else falls through to the BFF unchanged.
api.baalvion.com {
	encode gzip zstd

	# Public CMS delivery (UNAUTHENTICATED) — the live sites (imperialpedia, law, about, …) fetch
	# published content from api.baalvion.com/api/v1/public/*. cms-service is in app-platform:3018.
	# The per-tenant key vault (/api/v1/internal/*) is NEVER exposed here — deny it explicitly.
	@cms_internal path /api/v1/internal/* /internal/*
	handle @cms_internal {
		respond "Forbidden" 403
	}
	@cms_public path /api/v1/public /api/v1/public/*
	handle @cms_public {
		reverse_proxy app-platform:3018
	}

	# Payment public surface (Java PSP gateway, app-payments:3015 — runs under --profile payments):
	# initiate a charge, read its status, receive provider webhooks (HMAC-verified inside the svc).
	# Money-OUT (refund/capture) + actuator are denied at the edge (listed first → first match wins).
	@pay_locked path /v1/gateway/payments/*/refund /v1/gateway/payments/*/capture /actuator/*
	handle @pay_locked {
		respond "Forbidden" 403
	}
	@pay path /v1/gateway/payments /v1/gateway/payments/* /v1/gateway/webhooks/*
	handle @pay {
		reverse_proxy app-payments:3015
	}

	# Everything else → the consumer/admin BFF (proxy-service, session-gated) — unchanged.
	handle {
		reverse_proxy app-edge-realtime:4000
	}
}

# ── Realtime websocket stream → edge-realtime app (socket.io fan-out) ──
ws.baalvion.com {
	reverse_proxy app-edge-realtime:3040
}

# ── Admin platform → admin-web console, with auth + CMS BFF carve-outs ──
# The browser only ever sees same-origin /auth-bff + /api-bff; Caddy terminates them at the
# edge so the httpOnly refresh cookie + the Bearer the console holds reach the right backend.
# Everything else is the Next.js standalone admin console (admin-web:3030).
admin.baalvion.com {
	encode gzip zstd
	# Auth BFF shim → identity app (matches the proven core-stack /auth-bff → /v1/auth rewrite).
	handle_path /auth-bff/* {
		rewrite * /v1/auth{uri}
		reverse_proxy app-identity:3001
	}
	# CMS admin API BFF: the admin image calls /api-bff/knowledge/cms/api/v1/* with the Bearer it
	# already holds; terminate at the edge → cms-service (strips the prefix → /api/v1/*).
	handle_path /api-bff/knowledge/cms/* {
		reverse_proxy app-platform:3018
	}
	# Platform admin API BFF: the admin image calls /api-bff/platform/admin/v1/* (dashboard
	# stats, users, orgs, sessions, audit-logs). handle_path strips the prefix → admin-service
	# receives /v1/* (it mounts at /v1). Without this the console fell back to the public
	# api.baalvion.com path, which the edge BFF does not route → 404 "Route not found".
	handle_path /api-bff/platform/admin/* {
		reverse_proxy app-platform:3021
	}
	# Identity session API BFF: the admin image calls /api-bff/identity/session/v1/* (active
	# sessions + session stats). session-service mounts at /v1 → strip prefix → /v1/*.
	handle_path /api-bff/identity/session/* {
		reverse_proxy app-identity:3022
	}
	# ── Per-domain service consoles (same-origin /api-bff/<domain>/<service>) ──
	# Each strips its /api-bff/<domain>/<service> prefix; the service then receives its own
	# mount (/api/v1 or /v1) + endpoint, exactly as the local /__api/<service> proxy does.
	# Ports are the pm2-assigned ports — some are remapped from the standalone default
	# (rbac 3055→3053, marketplace 3062→3060). Without these the console fell back to
	# api.baalvion.com, which the edge BFF does not route → 404 "Route not found".
	handle_path /api-bff/identity/oauth/*              { reverse_proxy app-identity:3023 }
	handle_path /api-bff/identity/rbac/*               { reverse_proxy app-identity:3053 }
	handle_path /api-bff/platform/dashboard/*          { reverse_proxy app-platform:3009 }
	handle_path /api-bff/knowledge/imperialpedia/*     { reverse_proxy app-platform:3004 }
	handle_path /api-bff/knowledge/law/*               { reverse_proxy app-platform:3015 }
	handle_path /api-bff/infrastructure/audit/*        { reverse_proxy app-platform:3032 }
	handle_path /api-bff/infrastructure/notification/* { reverse_proxy app-edge-realtime:3031 }
	handle_path /api-bff/commerce/commerce/*           { reverse_proxy app-commerce:3012 }
	handle_path /api-bff/commerce/market/*             { reverse_proxy app-commerce:3007 }
	handle_path /api-bff/commerce/inventory/*          { reverse_proxy app-commerce:3014 }
	handle_path /api-bff/commerce/fulfillment/*        { reverse_proxy app-commerce:3016 }
	handle_path /api-bff/ecosystem/jobs/*              { reverse_proxy app-ecosystem:3002 }
	handle_path /api-bff/ecosystem/mining/*            { reverse_proxy app-ecosystem:3003 }
	handle_path /api-bff/ecosystem/real-estate/*       { reverse_proxy app-ecosystem:3005 }
	handle_path /api-bff/ecosystem/brand-connector/*   { reverse_proxy app-ecosystem:3006 }
	handle_path /api-bff/ecosystem/ir/*                { reverse_proxy app-ecosystem:3008 }
	handle_path /api-bff/ecosystem/about/*             { reverse_proxy app-ecosystem:3010 }
	handle_path /api-bff/ecosystem/ctm/*               { reverse_proxy app-ecosystem:3017 }
	handle_path /api-bff/ecosystem/crm/*               { reverse_proxy app-ecosystem:3063 }
	# CMS public delivery bypasses the session gateway → knowledge/cms-service.
	handle /api/v1/public/* {
		reverse_proxy app-platform:3018
	}
	# Everything else → the admin console (Next.js standalone). app-platform:3021 (admin-service
	# API) stays internal — it is NOT a browser surface and 404s on GET /.
	reverse_proxy admin-web:3030
}

# ── Direct service APIs (gateway-signed): add one block per public surface as needed,
#    always pointing at <app>:<port>. Examples:
#      commerce.baalvion.com   -> app-commerce:3013   (order-service)
#      trade.baalvion.com      -> app-trade:3052      (order-execution-service)
#      ir.baalvion.com         -> app-ecosystem:3008  (ir-service)
