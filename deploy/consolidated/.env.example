# ─────────────────────────────────────────────────────────────────────────────
# Consolidated backend — environment. Copy to `.env` (gitignored) and fill in.
# Same variable names your core-stack already uses, so service appConfig reads them
# unchanged. Every Node module inherits these via the container env; pm2 then adds the
# per-process PORT from its ecosystem file.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── PostgreSQL on AWS RDS (single database; each domain owns an isolated schema) ──
DB_HOST=baalvion-prod.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=baalvion
DB_USER=baalvion_app
DB_PASSWORD=__set_me__
DB_SSL=true                      # RDS → TLS required
DB_JDBC_PARAMS=?sslmode=require  # consumed by the Java payment service

# ── Redis (on-box container now; ElastiCache later) ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Shared auth / trust-boundary secrets (RS256 single-issuer per CLAUDE.md) ──
GATEWAY_SIGNING_SECRET=__set_me_min32__
INTERNAL_SERVICE_SECRET=__set_me_min32__
# auth-service RS256 keypair. auth-node normalizePem() accepts a file PATH, an inline PEM,
# or a \n-escaped PEM — these exact var names are what the code reads (NOT *_PATH).
JWT_PRIVATE_KEY=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY=/run/secrets/jwt_public.pem

# ── CORS / public origins ──
CORS_ORIGINS=https://app.baalvion.com,https://admin.baalvion.com,https://auth.baalvion.com

# ── Provider / channel keys (per-service; fill the ones your live surfaces use) ──
# RAZORPAY_KEY_ID=...           # commerce/order, ctm, payment
# RAZORPAY_KEY_SECRET=...
# SES / SMTP for notification + auth email-OTP:
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_USER=...
# SMTP_PASS=...
# S3_BUCKET / AWS creds for trade-service, law-service, cms media:
# AWS_REGION=ap-south-1
# S3_BUCKET=...
#
# NOTE: a handful of services read a couple of bespoke vars (e.g. ml-service MODEL_DIR,
# search-service OPENSEARCH_URL, network-graph NEO4J_URI). Grep each domain's
# config/appConfig.js and add any it requires — this env mapping is the ONLY integration
# step; no service code changes.

# ── Inter-service discovery (consolidated container DNS) — REQUIRED ──
# Cross-container calls must use app-<container>:<pm2 port> (pm2 PORT overrides the standalone
# default, e.g. rbac=3053 not 3055). See docs/deployment/production/08-service-dependency-map.md.
AUTH_SERVICE_URL=http://app-identity:3001
JWKS_URI=http://app-identity:3001/.well-known/jwks.json
RBAC_BASE_URL=http://app-identity:3053
RBAC_API_PREFIX=/v1
INVENTORY_BASE_URL=http://app-commerce:3014
INVENTORY_API_PREFIX=/api/v1
INVENTORY_INTERNAL_KEY=__set_me_min32__
SVC_TRADE=http://app-commerce:3025
CMS_BASE_URL=http://app-platform:3018
CMS_INTERNAL_URL=http://app-platform:3018
SVC_IMPERIALPEDIA=http://app-platform:3004
SVC_DASHBOARD=http://app-platform:3009
ADMIN_SERVICE_URL=http://app-platform:3021
SVC_MINING=http://app-ecosystem:3003
SVC_IR=http://app-ecosystem:3008
SVC_CTM=http://app-ecosystem:3017
SVC_INSIDERS=http://app-ecosystem:3050
SVC_ORDER_EXECUTION=http://app-trade:3052
NOTIFICATION_BASE_URL=http://app-edge-realtime:3031
NOTIFICATION_API_PREFIX=/v1
SVC_PROXY=http://app-edge-realtime:4000
SVC_PAYMENT=http://app-payments:3015
PAYMENT_SERVICE_URL=http://app-payments:3015
FINANCE_ENABLED=false
STOREFRONT_URL=https://app.baalvion.com
APP_URL=https://app.baalvion.com
# External-facing URLs — replace localhost fallbacks with real hostnames in production.
FRONTEND_URL=https://app.baalvion.com
API_BASE_URL=https://auth.baalvion.com
OAUTH_PUBLIC_BASE_URL=https://auth.baalvion.com
AUTH_UI_URL=https://app.baalvion.com/login
PAYU_RETURN_URL=https://app.baalvion.com/checkout/return
OBS_PROBE_AUTH_URL=http://app-identity:3001
