# ─────────────────────────────────────────────────────────────────────────────
# Consolidated backend — environment. Copy to `.env` (gitignored) and fill in.
# Same variable names your core-stack already uses, so service appConfig reads them
# unchanged. Every Node module inherits these via the container env; pm2 then adds the
# per-process PORT from its ecosystem file.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── PostgreSQL on AWS RDS (single database; each domain owns an isolated schema) ──
DB_HOST=baalvion-prod.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=baalvion
DB_USER=baalvion_app
DB_PASSWORD=__set_me__
DB_SSL=true                      # RDS → TLS required
DB_JDBC_PARAMS=?sslmode=require  # consumed by the Java payment service

# ── Redis (on-box container now; ElastiCache later) ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Shared auth / trust-boundary secrets (RS256 single-issuer per CLAUDE.md) ──
GATEWAY_SIGNING_SECRET=__set_me_min32__
INTERNAL_SERVICE_SECRET=__set_me_min32__
# auth-service RS256 keypair (mount or inject; path or PEM per its appConfig).
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# ── CORS / public origins ──
CORS_ORIGINS=https://app.baalvion.com,https://admin.baalvion.com,https://auth.baalvion.com

# ── Provider / channel keys (per-service; fill the ones your live surfaces use) ──
# RAZORPAY_KEY_ID=...           # commerce/order, ctm, payment
# RAZORPAY_KEY_SECRET=...
# SES / SMTP for notification + auth email-OTP:
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_USER=...
# SMTP_PASS=...
# S3_BUCKET / AWS creds for trade-service, law-service, cms media:
# AWS_REGION=ap-south-1
# S3_BUCKET=...
#
# NOTE: a handful of services read a couple of bespoke vars (e.g. ml-service MODEL_DIR,
# search-service OPENSEARCH_URL, network-graph NEO4J_URI). Grep each domain's
# config/appConfig.js and add any it requires — this env mapping is the ONLY integration
# step; no service code changes.
