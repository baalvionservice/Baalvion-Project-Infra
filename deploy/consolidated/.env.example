# ─────────────────────────────────────────────────────────────────────────────
# Consolidated backend — environment. Copy to `.env` (gitignored) and fill in.
# Same variable names your core-stack already uses, so service appConfig reads them
# unchanged. Every Node module inherits these via the container env; pm2 then adds the
# per-process PORT from its ecosystem file.
#
# This list is what a full local dry-run of all 6 apps proved is required to boot the
# fleet under NODE_ENV=production (services fail-closed on missing secrets — they will
# NOT degrade to insecure defaults). Fill every __set_me__.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── PostgreSQL on AWS RDS (single database; each domain owns an isolated schema) ──
DB_HOST=baalvion-prod.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=baalvion
DB_USER=baalvion_app
DB_PASSWORD=__set_me__
DB_SSL=true                      # RDS → TLS required (set false only for a non-TLS local PG)
DB_JDBC_PARAMS=?sslmode=require  # consumed by the Java payment service

# ── Redis (on-box container now; ElastiCache later) ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── RS256 signing (auth-service ISSUES tokens) ───────────────────────────────────
# auth-service loads the keypair in this priority (config/vault.js): file path → base64
# env → inline PEM. Pick ONE form:
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
# …or base64 (good for CI/containers — no file mounts):
# JWT_PRIVATE_KEY_B64=__base64_of_private_pem__
# JWT_PUBLIC_KEY_B64=__base64_of_public_pem__

# ── RS256 verification (EVERY other service VERIFIES via @baalvion/auth-node) ─────
# REQUIRED fleet-wide. auth-node's normalizePem treats a value containing "-----BEGIN" as
# an inline PEM (\n is un-escaped), otherwise as a FILE PATH it reads. So set EITHER an
# inline single-line PEM (newlines as \n) OR a path to the public-key file. Must match the
# keypair auth-service signs with, or token verification fails across the platform.
JWT_PUBLIC_KEY=/run/secrets/jwt_public.pem
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Legacy HS256 secrets (proxy-service, trade-service, insiders-service) ─────────
# openssl rand -hex 32
JWT_ACCESS_SECRET=__set_me_hex32__
JWT_REFRESH_SECRET=__set_me_hex32__
# proxy-service billing/compliance signer:
BILLING_SIGNING_SECRET=__set_me_hex32__

# ── Trust-boundary + internal service secrets (openssl rand -hex 32) ──────────────
GATEWAY_SIGNING_SECRET=__set_me_hex32__   # auth-gateway
INTERNAL_SERVICE_SECRET=__set_me_hex32__  # notification + service-to-service
RBAC_INTERNAL_API_KEY=__set_me_hex32__    # commerce/order → rbac (fail-closed)
AUDIT_INTERNAL_KEY=__set_me_hex32__       # audit ingestion
CMS_SECRETS_KEY=__set_me_hex32__          # cms vault
METRICS_SECRET=__set_me_hex32__           # proxy-service /metrics guard (REQUIRED in prod)
CART_SESSION_SECRET=__set_me_hex32__      # order-service signed cart
PROVIDER_SECRET_KEY=__set_me_hex32__      # proxy-service provider auth

# ── Per-service production config flags (fail-closed defaults) ────────────────────
ISLAND_AUTH_MODE=strict                   # trade-service refuses 'hybrid' outside development
FINANCE_WEBHOOK_SECRET=__set_me_hex32__   # order-execution-service finance webhook

# ── CORS / public origins ──
CORS_ORIGINS=https://app.baalvion.com,https://admin.baalvion.com,https://auth.baalvion.com

# ── External backends (the services that use them won't boot without these) ───────
# network-graph-service → Neo4j:
NEO4J_URI=bolt://your-neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=__set_me__
NEO4J_DATABASE=neo4j
# notification-service → an email provider (SMTP *or* Resend). It fail-closes without one:
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=__set_me__
SMTP_PASS=__set_me__
EMAIL_FROM=noreply@baalvion.com
# RESEND_API_KEY=__set_me__               # alternative to SMTP
# search-service → OpenSearch; jobs-service → Elasticsearch:
# OPENSEARCH_URL=https://your-opensearch:9200
# ELASTICSEARCH_NODE=https://your-es:9200

# ── Provider / channel keys (per-service; fill the ones your live surfaces use) ───
# RAZORPAY_KEY_ID=...           # commerce/order, ctm, payment
# RAZORPAY_KEY_SECRET=...
# PSP_MOCK=true                 # mock payments (no real charges) until live keys are set
# S3 / object storage for trade-service, law-service, cms media:
# AWS_REGION=ap-south-1
# S3_BUCKET=...
# ml-service (optional Python accelerator; OFF by default):
# MODEL_DIR=/var/lib/baalvion/models
#
# NOTE: a clean install builds the @baalvion/* packages in the image (Dockerfile.node runs
# the workspace build). The only remaining integration step is this env mapping — no service
# code changes. Grep each domain's config/appConfig.js if a surface needs a var not listed here.
