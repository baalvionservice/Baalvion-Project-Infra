# ═════════════════════════════════════════════════════════════════════════════
# Baalvion consolidated backend — PRODUCTION environment template.
# Copy to `.env` (gitignored) and inject real values from AWS SSM Parameter Store /
# Secrets Manager at deploy time. NEVER commit a filled-in copy.
#
# Legend:  [SECRET] = store in Secrets Manager / SSM SecureString, rotate on schedule.
#          [CONFIG] = non-secret config, fine in SSM String / plain .env.
#          [PROD-CRITICAL] = wrong value breaks prod (see notes).
# ═════════════════════════════════════════════════════════════════════════════

NODE_ENV=production                                    # [CONFIG]

# ── PostgreSQL on AWS RDS (one DB; each domain owns an isolated schema) ──────────
DB_HOST=baalvion-prod.xxxxxxxx.ap-south-1.rds.amazonaws.com   # [CONFIG]
DB_PORT=5432                                            # [CONFIG]
DB_NAME=baalvion                                        # [CONFIG]
DB_USER=baalvion_app                                    # [CONFIG] needs CREATE on the DB for boot-time schema sync
DB_PASSWORD=__from_secrets_manager__                   # [SECRET]
DB_SSL=true                                             # [PROD-CRITICAL] RDS requires TLS
DB_JDBC_PARAMS=?sslmode=require                         # [PROD-CRITICAL] Java payment service TLS

# ── Redis (on-box container; → ElastiCache at scale) ────────────────────────────
REDIS_HOST=redis                                        # [CONFIG]
REDIS_PORT=6379                                         # [CONFIG]

# ── Neo4j (on-box; network-graph-service HARD-EXITS without it) ─────────────────
NEO4J_URI=bolt://neo4j:7687                             # [CONFIG] [PROD-CRITICAL]
NEO4J_USER=neo4j                                        # [CONFIG]
NEO4J_PASSWORD=__from_secrets_manager__                # [SECRET]
NEO4J_DATABASE=neo4j                                    # [CONFIG]

# ── RS256 auth keys (single issuer per CLAUDE.md) ───────────────────────────────
# auth-service SIGNS using the B64 private key (vault.js).
JWT_PRIVATE_KEY_B64=__from_secrets_manager__           # [SECRET] base64 of the RSA private PEM
# ⚠ [PROD-CRITICAL] FLEET CONSUMERS verify with JWT_PUBLIC_KEY and use its VALUE AS THE KEY
#   (appConfig: requireEnv('JWT_PUBLIC_KEY').replace(/\n/g,'\n')). It must be the PEM itself,
#   NOT a file path. A path here → "secretOrPublicKey must be an asymmetric key" → 401 on every
#   authenticated cross-service call. Provide the PEM as a single-line \n-escaped string:
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n<base64 lines>\n-----END PUBLIC KEY-----   # [SECRET]
JWT_ISSUER=baalvion-auth                                # [CONFIG]
JWT_AUDIENCE=baalvion-platform                          # [CONFIG]
JWT_ACCESS_SECRET=__from_secrets_manager_min32__       # [SECRET]
JWT_REFRESH_SECRET=__from_secrets_manager_min32__      # [SECRET]

# ── Trust-boundary / internal secrets (all ≥32 chars, rotate) ───────────────────
GATEWAY_SIGNING_SECRET=__from_secrets_manager_min32__  # [SECRET]
INTERNAL_SERVICE_SECRET=__from_secrets_manager_min32__ # [SECRET] x-internal-secret between services
METRICS_SECRET=__from_secrets_manager__                # [SECRET]
CART_SESSION_SECRET=__from_secrets_manager__           # [SECRET] order-service signed guest cart
BILLING_SIGNING_SECRET=__from_secrets_manager__        # [SECRET]
RBAC_INTERNAL_API_KEY=__from_secrets_manager__         # [SECRET]
AUDIT_INTERNAL_KEY=__from_secrets_manager__            # [SECRET]
CMS_SECRETS_KEY=__from_secrets_manager__               # [SECRET] CMS provider-key vault encryption
PROVIDER_SECRET_KEY=__from_secrets_manager__           # [SECRET] proxy-service provider vault
FINANCE_WEBHOOK_SECRET=__from_secrets_manager__        # [SECRET] payment webhook signature

# ── Security posture (PROD values — NOT the dry-run values) ─────────────────────
ISLAND_AUTH_MODE=strict                                # [PROD-CRITICAL] fail-closed
PSP_MOCK=false                                          # [PROD-CRITICAL] real payment gateways
APP_SECURITY_ENABLED=false                              # [PROD-CRITICAL] JVM security OFF *only because*
#   the Caddy edge denies its sensitive paths (refund/capture/actuator/internal). Proven core-stack
#   pattern. If you flip this to true, configure the JVM's auth or webhooks will 401. Decide explicitly.
RATE_LIMIT_IP_MAX=1000                                  # [CONFIG]

# ── CORS / public origins ───────────────────────────────────────────────────────
CORS_ORIGINS=https://app.baalvion.com,https://admin.baalvion.com,https://auth.baalvion.com   # [CONFIG]

# ── Email — Amazon SES over SMTP (587 STARTTLS, valid cert) ─────────────────────
# ⚠ The mailer hardcodes requireTLS for non-465 ports. SES (587 STARTTLS + trusted cert) works.
#   Do NOT use the dry-run Mailpit / self-signed cert / NODE_TLS_REJECT_UNAUTHORIZED=0 in prod.
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com          # [CONFIG]
SMTP_PORT=587                                           # [CONFIG]
SMTP_USER=__ses_smtp_username__                        # [SECRET] SES SMTP creds (NOT IAM keys)
SMTP_PASS=__ses_smtp_password__                        # [SECRET]
EMAIL_FROM=noreply@baalvion.com                        # [CONFIG] must be an SES-verified identity
# RESEND_API_KEY=__optional__                          # [SECRET] alternative provider (tried before SMTP)

# ── Object storage (trade-service, law-service, cms media) ──────────────────────
AWS_REGION=ap-south-1                                   # [CONFIG]
S3_BUCKET=baalvion-prod-media                           # [CONFIG] (prefer IAM instance role over keys)
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY: omit — use the EC2 instance role.

# ── Search (optional; absent ⇒ documented degraded mode) ────────────────────────
# OPENSEARCH_URL=https://vpc-baalvion-xxxx.ap-south-1.es.amazonaws.com   # [CONFIG] search-service
# ES_URL=https://...                                    # [CONFIG] jobs-service (else DB fallback)

# ── Payment provider keys (live surfaces; usually synced from the CMS vault) ─────
# RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET / PAYU_* / CASHFREE_* — [SECRET], per live site.

# ── Kafka (payments JVM) ────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092                              # [CONFIG] (→ MSK bootstrap at scale)

# ── Inter-service discovery (consolidated container DNS) ─────────────────────────
# [PROD-CRITICAL] cross-container calls MUST use app-<container>:<pm2 port> (pm2 PORT overrides
# the standalone default, e.g. rbac=3053 not 3055). Without these, order/trade/cms/payment call
# paths break or silently fail-open. See docs/deployment/production/08-service-dependency-map.md.
AUTH_SERVICE_URL=http://app-identity:3001
JWKS_URI=http://app-identity:3001/.well-known/jwks.json
RBAC_BASE_URL=http://app-identity:3053                  # rbac.failMode=closed → checkout breaks if wrong
RBAC_API_PREFIX=/v1
INVENTORY_BASE_URL=http://app-commerce:3014
INVENTORY_API_PREFIX=/api/v1
INVENTORY_INTERNAL_KEY=__from_secrets_manager__        # [SECRET] shared order↔inventory key
SVC_TRADE=http://app-commerce:3025
CMS_BASE_URL=http://app-platform:3018                   # NOT localhost — prod guard rejects it
CMS_INTERNAL_URL=http://app-platform:3018
SVC_IMPERIALPEDIA=http://app-platform:3004
SVC_DASHBOARD=http://app-platform:3009
ADMIN_SERVICE_URL=http://app-platform:3021
SVC_MINING=http://app-ecosystem:3003
SVC_IR=http://app-ecosystem:3008
SVC_CTM=http://app-ecosystem:3017
SVC_INSIDERS=http://app-ecosystem:3050
SVC_ORDER_EXECUTION=http://app-trade:3052
NOTIFICATION_BASE_URL=http://app-edge-realtime:3031
NOTIFICATION_API_PREFIX=/v1
SVC_PROXY=http://app-edge-realtime:4000
SVC_PAYMENT=http://app-payments:3015
PAYMENT_SERVICE_URL=http://app-payments:3015
FINANCE_ENABLED=false                                   # full Java finance reactor not in this stack
STOREFRONT_URL=https://app.baalvion.com                 # real consumer site (payment redirects + email links)
APP_URL=https://app.baalvion.com
# External-facing URLs — [PROD-CRITICAL] replace localhost fallbacks with real hostnames.
FRONTEND_URL=https://app.baalvion.com                   # auth reset-password / OAuth redirect base
API_BASE_URL=https://auth.baalvion.com                  # auth-service self/JWKS issuer base (external)
OAUTH_PUBLIC_BASE_URL=https://auth.baalvion.com         # OAuth callback base
AUTH_UI_URL=https://app.baalvion.com/login              # oauth-service login redirect
PAYU_RETURN_URL=https://app.baalvion.com/checkout/return
OBS_PROBE_AUTH_URL=http://app-identity:3001             # ctm observability health probe (internal)

# ── Superadmin bootstrap (run once, then rotate the password) ───────────────────
SUPERADMIN_EMAIL=ops@baalvion.com                      # [CONFIG]
SUPERADMIN_PASSWORD=__strong_unique_rotate_after_use__ # [SECRET]  NOT the dry-run "BaalvionDryRun!2026"

# ── Image / deploy (set by CI, not hand-edited) ─────────────────────────────────
ECR_REGISTRY=<acct>.dkr.ecr.ap-south-1.amazonaws.com   # [CONFIG]
IMAGE_TAG=prod-<gitsha>                                 # [CONFIG] pin to a sha, not prod-latest, for rollback

# ═════════════════════════════════════════════════════════════════════════════
# DRY-RUN-ONLY VARS THAT MUST NOT APPEAR IN PRODUCTION .env:
#   NODE_TLS_REJECT_UNAUTHORIZED=0   · SMTP_HOST=mailpit · PSP_MOCK=true
#   JWT_*_B64 dev keypairs · SUPERADMIN_PASSWORD=BaalvionDryRun!2026
# See docs/deployment/production/00-README.md §"Dry-run → production exclusions".
# ═════════════════════════════════════════════════════════════════════════════
