# ─────────────────────────────────────────────────────────────────────────────
# Host runtime environment for the CORE stack on EC2 (ECR pull flow).
# Copy to `.env.production` ON THE HOST and fill every __CHANGE_ME__. NEVER commit it.
# Used by deploy/core-stack/deploy.sh (pull + up -d --no-build) and the runtime compose.
#
#   cp deploy/core-stack/.env.production.example deploy/core-stack/.env.production
#   nano deploy/core-stack/.env.production
#
# Differs from .env.prod.example only by the ECR image-source block below — everything
# under "App config" is identical to a local .env.prod.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image source (Amazon ECR) — the host PULLS these; CI builds + pushes them ──
# IMAGE_PREFIX = <account>.dkr.ecr.<region>.amazonaws.com/baalvion  (the `baalvion` namespace
# must match ECR_NAMESPACE in the workflow). The compose appends /core-<svc>:<IMAGE_TAG>.
IMAGE_PREFIX=__CHANGE_ME__.dkr.ecr.ap-south-1.amazonaws.com/baalvion
# prod-latest follows the newest build; pin a commit SHA or RELEASE_TAG for an immutable host.
IMAGE_TAG=prod-latest
AWS_REGION=ap-south-1

# ── Domains + TLS (Caddy / Let's Encrypt) — point each A record at this host ──
DOMAIN_API=api.baalvion.com
DOMAIN_CMS=cms.baalvion.com
DOMAIN_ADMIN=admin.baalvion.com
# Shared brand-aware sign-in surface (auth-baalvion). Every Baalvion site delegates "Sign in" here.
DOMAIN_AUTH=auth.baalvion.com
ACME_EMAIL=__CHANGE_ME__

# ── PostgreSQL (in-compose; swap to RDS by pointing DB_HOST at the RDS endpoint) ─
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
DB_HOST=postgres
DB_PORT=5432
DB_SSL=false
DB_JDBC_PARAMS=

# ── Redis (in-compose) ───────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── RS256 signing keypair (auth mints; cms + payment verify) — single-line PEMs ──
JWT_PRIVATE_KEY=__CHANGE_ME__
JWT_PUBLIC_KEY=__CHANGE_ME__
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Shared secrets (MUST match across cms + payment; openssl rand -hex 32) ────
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__
CMS_SECRETS_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── Super-admin (bootstraps login + authenticates seeds/console) ──────────────
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=__CHANGE_ME__

# ── CORS + rate limit ────────────────────────────────────────────────────────
# Include every browser origin that calls auth-service cross-origin: the admin console, the shared
# sign-in surface, and any consumer site that hits auth-service directly (e.g. cross-apex Amarisé).
CORS_ORIGINS=https://admin.baalvion.com,https://auth.baalvion.com
RATE_LIMIT_IP_MAX=5000

# ── payment-service ↔ CMS vault (internal) ───────────────────────────────────
CMS_BASE_URL=http://cms-service:3011/api/v1
APP_SECURITY_ENABLED=false
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0

# ── Razorpay (PSP_MOCK=true → no real charges; flip to false for live) ────────
PSP_MOCK=true
RAZORPAY_BASE_URL=https://api.razorpay.com
# (A) GLOBAL mode: set these + call WITHOUT ?site=.  (B) CMS-vault mode: leave blank + store
# per-site keys in the admin console vault + call WITH ?site=<slug>. See README.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── auth-gateway BFF (only used with `--profile admin`) ───────────────────────
GATEWAY_SIGNING_SECRET=__CHANGE_ME__

# ── Transactional email — AWS SES (REQUIRED for passwordless email-OTP login) ──
# Used by password reset, member invites, AND email-OTP login (/v1/auth/email/otp/*). Without a
# real SMTP_HOST, auth-service refuses to issue login codes in production (it will NOT silently
# no-op). Verify the sender in SES (move out of sandbox), create SES SMTP creds, set them below.
EMAIL_FROM=noreply@baalvion.com
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=__CHANGE_ME__ses_smtp_username__
SMTP_PASS=__CHANGE_ME__ses_smtp_password__
# Brand shown in the OTP email subject/body (defaults to "Baalvion").
OTP_EMAIL_BRAND=Baalvion

# ── Shared sign-in surface (auth.baalvion.com) — passwordless email-OTP SSO ───
# Cross-subdomain SSO: scope the auth-service refresh cookie to the apex so ONE sign-in on the
# shared surface is shared by every *.baalvion.com site. Empty = host-only (no cross-site SSO).
REFRESH_COOKIE_DOMAIN=.baalvion.com
# Cloudflare Turnstile (anti-bot on the OTP-request endpoint). BOTH are needed in production:
#   TURNSTILE_SECRET_KEY           → server-side siteverify on auth-service (KEEP SECRET).
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY → baked into the auth-baalvion widget at image BUILD (public).
# Leave BOTH blank only for a dev build with no captcha.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Extra non-baalvion.com return_to apexes allowed by the surface (comma-separated). *.baalvion.com
# is always allowed. e.g. amarisemaisonavenue.com,baalvionstack.com,controlthemarket.com
AUTH_ALLOWED_RETURN_HOSTS=

# ─────────────────────────────────────────────────────────────────────────────
# Platform + commerce services (rbac · audit · commerce · order · trade · notification)
# Added onto the core. Internal-only; each owns an isolated Postgres schema in baalvion_db.
# ─────────────────────────────────────────────────────────────────────────────

# Internal service-to-service API keys (commerce/order call rbac fail-closed → MUST match).
#   openssl rand -hex 32
RBAC_INTERNAL_API_KEY=__CHANGE_ME__openssl_rand_hex_32__
AUDIT_INTERNAL_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── order-service (LIVE Razorpay, Node-direct checkout) ───────────────────────
# order-service is wired ALLOW_MOCK_PAYMENTS=false → it charges for real using the RAZORPAY_*
# keys above. Set those to your LIVE keys to take payments (the Java payment-service stays mock
# while PSP_MOCK=true). CART_SESSION_SECRET signs the server-side cart.  openssl rand -hex 32
CART_SESSION_SECRET=__CHANGE_ME__openssl_rand_hex_32__
# Optional CMS website slug order-service reads site config from (blank = none).
ORDER_PAYMENT_SITE_SLUG=
# inventory-service is NOT deployed in this slice → leave blank (stock-lock calls fail at request).
INVENTORY_BASE_URL=
INVENTORY_INTERNAL_KEY=

# ── commerce-service media (object storage; blank = uploads disabled, content still serves) ──
MEDIA_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── notification-service (uses SMTP_* above; optional Resend fallback) ────────
RESEND_API_KEY=

# ── trade-service ─────────────────────────────────────────────────────────────
TRADE_CORS_ORIGINS=
# Legacy HS256 access secret some trade internals expect (optional; RS256 via JWKS is primary).
JWT_ACCESS_SECRET=
# Firebase Admin (OPTIONAL — trade-service boots without it).
TRADE_FIREBASE_PROJECT_ID=
TRADE_FIREBASE_CLIENT_EMAIL=
TRADE_FIREBASE_PRIVATE_KEY=
