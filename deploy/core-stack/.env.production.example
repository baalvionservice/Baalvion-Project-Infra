# ─────────────────────────────────────────────────────────────────────────────
# Host runtime environment for the CORE stack on EC2 (ECR pull flow).
# Copy to `.env.production` ON THE HOST and fill every __CHANGE_ME__. NEVER commit it.
# Used by deploy/core-stack/deploy.sh (pull + up -d --no-build) and the runtime compose.
#
#   cp deploy/core-stack/.env.production.example deploy/core-stack/.env.production
#   nano deploy/core-stack/.env.production
#
# Differs from .env.prod.example only by the ECR image-source block below — everything
# under "App config" is identical to a local .env.prod.
# ─────────────────────────────────────────────────────────────────────────────

# ── Image source (Amazon ECR) — the host PULLS these; CI builds + pushes them ──
# IMAGE_PREFIX = <account>.dkr.ecr.<region>.amazonaws.com/baalvion  (the `baalvion` namespace
# must match ECR_NAMESPACE in the workflow). The compose appends /core-<svc>:<IMAGE_TAG>.
IMAGE_PREFIX=__CHANGE_ME__.dkr.ecr.ap-south-1.amazonaws.com/baalvion
# prod-latest follows the newest build; pin a commit SHA or RELEASE_TAG for an immutable host.
IMAGE_TAG=prod-latest
AWS_REGION=ap-south-1

# ── Domains + TLS (Caddy / Let's Encrypt) — point each A record at this host ──
DOMAIN_API=api.baalvion.com
DOMAIN_CMS=cms.baalvion.com
DOMAIN_ADMIN=admin.baalvion.com
ACME_EMAIL=__CHANGE_ME__

# ── PostgreSQL (in-compose; swap to RDS by pointing DB_HOST at the RDS endpoint) ─
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
DB_HOST=postgres
DB_PORT=5432
DB_SSL=false
DB_JDBC_PARAMS=

# ── Redis (in-compose) ───────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── RS256 signing keypair (auth mints; cms + payment verify) — single-line PEMs ──
JWT_PRIVATE_KEY=__CHANGE_ME__
JWT_PUBLIC_KEY=__CHANGE_ME__
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Shared secrets (MUST match across cms + payment; openssl rand -hex 32) ────
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__
CMS_SECRETS_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── Super-admin (bootstraps login + authenticates seeds/console) ──────────────
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=__CHANGE_ME__

# ── CORS + rate limit ────────────────────────────────────────────────────────
CORS_ORIGINS=https://admin.baalvion.com
RATE_LIMIT_IP_MAX=5000

# ── payment-service ↔ CMS vault (internal) ───────────────────────────────────
CMS_BASE_URL=http://cms-service:3011/api/v1
APP_SECURITY_ENABLED=false
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0

# ── Razorpay (PSP_MOCK=true → no real charges; flip to false for live) ────────
PSP_MOCK=true
RAZORPAY_BASE_URL=https://api.razorpay.com
# (A) GLOBAL mode: set these + call WITHOUT ?site=.  (B) CMS-vault mode: leave blank + store
# per-site keys in the admin console vault + call WITH ?site=<slug>. See README.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── auth-gateway BFF (only used with `--profile admin`) ───────────────────────
GATEWAY_SIGNING_SECRET=__CHANGE_ME__

# ── Transactional email (optional) ───────────────────────────────────────────
EMAIL_FROM=noreply@baalvion.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
