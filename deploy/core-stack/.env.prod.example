# ─────────────────────────────────────────────────────────────────────────────
# Production environment for the CORE 3-service stack (single EC2 + Docker Compose).
# Copy to `.env.prod` and fill every __CHANGE_ME__. NEVER commit the real .env.prod.
# Generate strong secrets with:  openssl rand -hex 32
#
#   cp deploy/core-stack/.env.prod.example deploy/core-stack/.env.prod
#   nano deploy/core-stack/.env.prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Container images (optional — for a CI→registry→pull flow) ────────────────
# Leave as-is to build locally with `up -d --build`. For a registry flow, set IMAGE_PREFIX
# to your ECR/registry namespace and pull pre-built IMAGE_TAG images.
IMAGE_PREFIX=baalvion
IMAGE_TAG=prod-latest

# ── Domains + TLS (Caddy / Let's Encrypt) — point each A record at this host ──
# Identity + payment API surface (/v1/auth, JWKS, /v1/gateway/*).
DOMAIN_API=api.baalvion.com
# CMS public delivery + admin API (Vercel sites read https://${DOMAIN_CMS}/api/v1/public).
DOMAIN_CMS=cms.baalvion.com
# Admin console (only used when you run `--profile admin`).
DOMAIN_ADMIN=admin.baalvion.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=__CHANGE_ME__

# ── PostgreSQL (internal to the compose network; never published) ────────────
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
# Host overrides — keep these as the compose service name unless you move to RDS.
DB_HOST=postgres
DB_PORT=5432
# In-compose Postgres has no TLS → false. For RDS: DB_SSL=true AND DB_JDBC_PARAMS=?sslmode=require
DB_SSL=false
DB_JDBC_PARAMS=

# ── Redis (internal) ─────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── RS256 signing keypair (auth-service MINTS; cms-service + payment-service VERIFY) ──
# Generate: cd Backend/services/identity/auth-service && npm run generate-keys
# Then single-line, \n-escape each PEM:
#   awk 'NF {printf "%s\\n", $0}' keys/private.pem   # -> JWT_PRIVATE_KEY
#   awk 'NF {printf "%s\\n", $0}' keys/public.pem    # -> JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=__CHANGE_ME__
JWT_PUBLIC_KEY=__CHANGE_ME__
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Shared secrets (REQUIRED — services refuse the dev defaults in production) ──
# Inter-service secret. cms-service uses it to guard the vault read; payment-service sends it
# as x-internal-secret. These MUST be the SAME value across both services.
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__
# CMS vault master key — AES-encrypts the stored PSP provider keys. Changing it after seeding
# the vault means you must re-enter the keys (old ciphertext won't decrypt).
CMS_SECRETS_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── Super-admin (bootstraps the login + authenticates the admin console / seeds) ──
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=__CHANGE_ME__

# ── CORS: browser origins allowed to call the auth + CMS admin APIs ───────────
# Server-side (SSR) fetches carry no Origin and are unaffected. Include the admin console and
# any browser client that talks to these APIs directly. Drop localhost in real production.
CORS_ORIGINS=https://admin.baalvion.com,http://localhost:3030,http://localhost:5173
# Per-IP cap for cms-service (200 default is too low for delivery + the admin console).
RATE_LIMIT_IP_MAX=5000

# ── payment-service ↔ CMS vault (internal) ───────────────────────────────────
CMS_BASE_URL=http://cms-service:3011/api/v1
# Permissive Java security (matches the proven stack; the public surface is locked at the edge).
# See README "Security posture" before changing.
APP_SECURITY_ENABLED=false
# Shared DB: baseline the Java service's own Flyway history on the shared schema.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0

# ── Razorpay ─────────────────────────────────────────────────────────────────
# PSP_MOCK=true → deterministic ids, NO real charges (safe first boot). Set false for real money.
PSP_MOCK=true
RAZORPAY_BASE_URL=https://api.razorpay.com
# TWO ways to supply keys (see README "Razorpay keys"):
#  (A) GLOBAL / single-tenant — set them here; clients call WITHOUT ?site=.
#  (B) CMS vault / per-tenant (keep current pattern) — LEAVE THESE BLANK, store keys per website
#      slug in the CMS "Integrations & Keys" vault (admin console), clients call WITH ?site=<slug>.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── auth-gateway BFF (only used with `--profile admin`) ───────────────────────
#   openssl rand -hex 32
GATEWAY_SIGNING_SECRET=__CHANGE_ME__

# ── Transactional email — AWS SES (REQUIRED for passwordless email-OTP login) ──
# Used by password reset, member invites, AND email-OTP login (/v1/auth/email/otp/*).
# Without a real SMTP_HOST, auth-service refuses to issue login codes in production
# (it will NOT silently no-op). Steps:
#   1. Verify the sender domain/address in AWS SES (and move SES out of sandbox).
#   2. Create SMTP credentials in the SES console → fill SMTP_USER / SMTP_PASS below.
#   3. EMAIL_FROM must be an SES-verified identity.
EMAIL_FROM=noreply@baalvion.com
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=__CHANGE_ME__ses_smtp_username__
SMTP_PASS=__CHANGE_ME__ses_smtp_password__
# Brand shown in the OTP email subject/body (defaults to "Baalvion").
OTP_EMAIL_BRAND=Baalvion

# ─────────────────────────────────────────────────────────────────────────────
# Platform + commerce services (rbac · audit · commerce · order · trade · notification)
# Added onto the core. Internal-only; each owns an isolated Postgres schema in baalvion_db.
# ─────────────────────────────────────────────────────────────────────────────

# Internal service-to-service API keys (commerce/order call rbac fail-closed → MUST match).
#   openssl rand -hex 32
RBAC_INTERNAL_API_KEY=__CHANGE_ME__openssl_rand_hex_32__
AUDIT_INTERNAL_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── order-service (LIVE Razorpay, Node-direct checkout) ───────────────────────
# order-service is wired ALLOW_MOCK_PAYMENTS=false → it charges for real using the RAZORPAY_*
# keys above. Set those to your LIVE keys to take payments (the Java payment-service stays mock
# while PSP_MOCK=true). CART_SESSION_SECRET signs the server-side cart.  openssl rand -hex 32
CART_SESSION_SECRET=__CHANGE_ME__openssl_rand_hex_32__
# Optional CMS website slug order-service reads site config from (blank = none).
ORDER_PAYMENT_SITE_SLUG=
# inventory-service is NOT deployed in this slice → leave blank (stock-lock calls fail at request).
INVENTORY_BASE_URL=
INVENTORY_INTERNAL_KEY=

# ── commerce-service media (object storage; blank = uploads disabled, content still serves) ──
MEDIA_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ── notification-service (uses SMTP_* above; optional Resend fallback) ────────
RESEND_API_KEY=

# ── trade-service ─────────────────────────────────────────────────────────────
TRADE_CORS_ORIGINS=
# Legacy HS256 access secret some trade internals expect (optional; RS256 via JWKS is primary).
JWT_ACCESS_SECRET=
# Firebase Admin (OPTIONAL — trade-service boots without it).
TRADE_FIREBASE_PROJECT_ID=
TRADE_FIREBASE_CLIENT_EMAIL=
TRADE_FIREBASE_PRIVATE_KEY=
