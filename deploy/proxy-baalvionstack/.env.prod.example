# ─────────────────────────────────────────────────────────────────────────────
# Production environment for proxy.baalvionstack.com (single-EC2 Docker Compose).
# Copy to `.env.prod` on the server and fill in REAL values. NEVER commit `.env.prod`.
# Generate strong secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Container images (Amazon ECR) — built + pushed by CI; the EC2 only PULLS these tags ──
# Set IMAGE_PREFIX to your ECR registry namespace. Images are built + pushed to ECR by the
# canonical pipeline (.github/workflows/deploy.yml). No GHCR is used anywhere in the pipeline.
IMAGE_PREFIX=<ACCOUNT_ID>.dkr.ecr.ap-south-1.amazonaws.com/baalvion
IMAGE_TAG=prod-latest

# ── Domain + TLS ─────────────────────────────────────────────────────────────
DOMAIN=proxy.baalvionstack.com
# Email Let's Encrypt uses for cert expiry notices (Caddy ACME).
ACME_EMAIL=ops@baalvion.com

# ── Public CMS (feeds the Vercel-hosted Next.js sites: about.baalvion.com, …) ──
# Caddy serves the read-only CMS content API (/api/v1/public/*) at this host with auto-TLS.
# Point its DNS A record at the SAME Elastic IP. Each Next.js site then sets, in Vercel:
#   CMS_PUBLIC_URL=https://${CMS_DOMAIN}/api/v1/public   and   CMS_WEBSITE_SLUG=<site-slug>
CMS_DOMAIN=cms.baalvion.com
# cms-service requires a JWT public key at boot even though the public read API is
# unauthenticated. Reuse proxy-service's RS256 public half as a SINGLE-LINE PEM (\n-escaped):
#   awk 'NF {printf "%s\\n", $0}' deploy/proxy-baalvionstack/secrets/keys/baalvion-key-1.pub
CMS_JWT_PUBLIC_KEY=__CHANGE_ME__single_line_PEM_of_baalvion-key-1.pub__
# Browser origins allowed to read the CMS directly (server-side SSR fetches don't need this).
CMS_CORS_ORIGINS=https://about.baalvion.com

# ── Postgres (in-compose; swap to RDS by pointing DB_HOST at the RDS endpoint) ─
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
# Services read these (DB_HOST=postgres is the compose service name; for RDS use its host).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=__CHANGE_ME__strong_db_password__
# ── Database TLS (REQUIRED when DB_HOST points at RDS / any non-localhost Postgres) ──
# In-compose Postgres on the same host has no TLS → DB_SSL=false. For RDS set DB_SSL=true,
# keep cert verification on, and pin the RDS CA bundle.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=<paste RDS CA bundle PEM, single line with \n escapes>
# ── RLS cutover (see Backend/docs/RLS-PRODUCTION-CUTOVER.md) ──
# Services connect as the owner role above, which BYPASSES Postgres RLS. After verifying tenant
# isolation per service, point DB_USER at the non-superuser baalvion_app role so RLS enforces.
# Run migrations as POSTGRES_USER (owner) — they must bypass RLS.
# DB_USER=baalvion_app
# DB_PASSWORD=__CHANGE_ME__baalvion_app_password__

# ── Redis (in-compose; swap to ElastiCache by changing REDIS_HOST) ────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Inter-service + crypto secrets (REQUIRED in production) ───────────────────
# Shared service-to-service secret (proxy-service ↔ payment-service ↔ cms vault).
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__
# CMS vault master key — decrypts the stored payment provider keys. If you change this
# AFTER seeding the vault, you must re-seed (old ciphertext won't decrypt).
CMS_SECRETS_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── proxy-service JWT (customer auth) ────────────────────────────────────────
# HS secrets back the refresh token; the ACCESS token is RS256 from the mounted keypair
# (see runbook §5 — generate config/keys/baalvion-key-1.{key,pub} and mount it).
JWT_ACCESS_SECRET=__CHANGE_ME__openssl_rand_hex_32__
JWT_REFRESH_SECRET=__CHANGE_ME__openssl_rand_hex_32__
JWT_ACTIVE_KID=baalvion-key-1
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Razorpay LIVE (real money) ───────────────────────────────────────────────
# From the Razorpay Dashboard (live mode). The webhook secret MUST equal the secret you
# set on the dashboard webhook pointing at https://${DOMAIN}/v1/billing/webhook/razorpay
RAZORPAY_KEY_ID=rzp_live___CHANGE_ME__
RAZORPAY_KEY_SECRET=__CHANGE_ME__
RAZORPAY_WEBHOOK_SECRET=__CHANGE_ME__dashboard_webhook_secret__
RAZORPAY_BASE_URL=https://api.razorpay.com

# ── Stripe (real money — best for international cards) ────────────────────────
# Hosted Stripe Checkout + S2S webhook. proxy-service needs STRIPE_WEBHOOK_SECRET to verify the
# webhook; the secret + publishable keys also go in the CMS vault (so payment-service creates the
# Checkout Session). In the Stripe dashboard add a webhook → https://${DOMAIN}/v1/billing/webhook/stripe
# for event checkout.session.completed, and set the vault config.baseUrl to https://api.stripe.com.
STRIPE_SECRET_KEY=sk_live___CHANGE_ME__
STRIPE_PUBLISHABLE_KEY=pk_live___CHANGE_ME__
STRIPE_WEBHOOK_SECRET=whsec___CHANGE_ME__

# ── PayU (real money) ────────────────────────────────────────────────────────
# PayU is a redirect/form-POST flow. proxy-service needs the merchant key+salt to verify the
# reverse-hash on PayU's callback (surl/furl → /v1/billing/webhook/payu). Same key+salt also go in
# the CMS vault (so payment-service can build the order). In the PayU dashboard set the production
# _payment URL (the SPA posts to VITE_PAYU_ACTION_URL=https://secure.payu.in/_payment in prod).
PAYU_MERCHANT_KEY=__CHANGE_ME__
PAYU_MERCHANT_SALT=__CHANGE_ME__

# ── Cashfree (real money) ────────────────────────────────────────────────────
# Cashfree = API order + JS-SDK redirect + S2S webhook. proxy-service needs the client SECRET to
# verify the webhook signature base64(HMAC-SHA256(timestamp+body, secret)). Same client id+secret
# also go in the CMS vault (so payment-service can create the order). Set the Cashfree dashboard
# webhook URL to https://${DOMAIN}/v1/billing/webhook/cashfree, and the vault config.baseUrl to
# https://api.cashfree.com for production (sandbox.cashfree.com for test).
CASHFREE_CLIENT_ID=__CHANGE_ME__
CASHFREE_CLIENT_SECRET=__CHANGE_ME__

# Shared by the PayU + Cashfree callbacks for the post-payment redirect back to the app.
PUBLIC_APP_URL=https://proxy.baalvionstack.com

# ── App config ───────────────────────────────────────────────────────────────
NODE_ENV=production
# Only the public site origin — drop all localhost dev origins in production.
CORS_ORIGINS=https://proxy.baalvionstack.com
# proxy-service → payment-service (internal compose network, not exposed publicly).
PAYMENT_SERVICE_URL=http://payment-service:3015
PAYMENT_SITE_SLUG=proxy-baalvionstack
# payment-service → CMS vault (internal).
CMS_BASE_URL=http://cms-service:3011/api/v1
# Real provider keys live in the CMS vault (mode=live); PSP_MOCK=false hits the real PSP.
PSP_MOCK=false
# Java suite has no IdP wired here and is not publicly exposed → permissive; tighten with OAuth later.
APP_SECURITY_ENABLED=false
# Shared DB: let each Java service baseline its own Flyway history on the shared schema.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0
