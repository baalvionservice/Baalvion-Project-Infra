# ─────────────────────────────────────────────────────────────────────────────
# Production environment for proxy.baalvionstack.com (single-EC2 Docker Compose).
# Copy to `.env.prod` on the server and fill in REAL values. NEVER commit `.env.prod`.
# Generate strong secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Container images (GHCR) — set by CI; the EC2 pulls these tags ─────────────
# Must match what the deploy workflow builds/pushes. Leave defaults unless your GHCR org differs.
IMAGE_PREFIX=ghcr.io/baalvionservice/baalvion
IMAGE_TAG=prod-latest

# ── Domain + TLS ─────────────────────────────────────────────────────────────
DOMAIN=proxy.baalvionstack.com
# Email Let's Encrypt uses for cert expiry notices (Caddy ACME).
ACME_EMAIL=ops@baalvion.com

# ── Postgres (in-compose; swap to RDS by pointing DB_HOST at the RDS endpoint) ─
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
# Services read these (DB_HOST=postgres is the compose service name; for RDS use its host).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=__CHANGE_ME__strong_db_password__

# ── Redis (in-compose; swap to ElastiCache by changing REDIS_HOST) ────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Inter-service + crypto secrets (REQUIRED in production) ───────────────────
# Shared service-to-service secret (proxy-service ↔ payment-service ↔ cms vault).
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__
# CMS vault master key — decrypts the stored payment provider keys. If you change this
# AFTER seeding the vault, you must re-seed (old ciphertext won't decrypt).
CMS_SECRETS_KEY=__CHANGE_ME__openssl_rand_hex_32__

# ── proxy-service JWT (customer auth) ────────────────────────────────────────
# HS secrets back the refresh token; the ACCESS token is RS256 from the mounted keypair
# (see runbook §5 — generate config/keys/baalvion-key-1.{key,pub} and mount it).
JWT_ACCESS_SECRET=__CHANGE_ME__openssl_rand_hex_32__
JWT_REFRESH_SECRET=__CHANGE_ME__openssl_rand_hex_32__
JWT_ACTIVE_KID=baalvion-key-1
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Razorpay LIVE (real money) ───────────────────────────────────────────────
# From the Razorpay Dashboard (live mode). The webhook secret MUST equal the secret you
# set on the dashboard webhook pointing at https://${DOMAIN}/v1/billing/webhook/razorpay
RAZORPAY_KEY_ID=rzp_live___CHANGE_ME__
RAZORPAY_KEY_SECRET=__CHANGE_ME__
RAZORPAY_WEBHOOK_SECRET=__CHANGE_ME__dashboard_webhook_secret__
RAZORPAY_BASE_URL=https://api.razorpay.com

# ── App config ───────────────────────────────────────────────────────────────
NODE_ENV=production
# Only the public site origin — drop all localhost dev origins in production.
CORS_ORIGINS=https://proxy.baalvionstack.com
# proxy-service → payment-service (internal compose network, not exposed publicly).
PAYMENT_SERVICE_URL=http://payment-service:3015
PAYMENT_SITE_SLUG=proxy-baalvionstack
# payment-service → CMS vault (internal).
CMS_BASE_URL=http://cms-service:3011/api/v1
# Real provider keys live in the CMS vault (mode=live); PSP_MOCK=false hits the real PSP.
PSP_MOCK=false
# Java suite has no IdP wired here and is not publicly exposed → permissive; tighten with OAuth later.
APP_SECURITY_ENABLED=false
# Shared DB: let each Java service baseline its own Flyway history on the shared schema.
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=0
