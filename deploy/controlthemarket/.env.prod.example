# ─────────────────────────────────────────────────────────────────────────────
# Production environment for controlthemarket.com (single-EC2 Docker Compose).
# Copy to `.env.prod` on the server and fill in REAL values. NEVER commit `.env.prod`.
# Generate strong secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Container images (GHCR) — set by CI; the EC2 pulls these tags ─────────────
# Must match what the deploy workflow builds/pushes. Leave defaults unless your GHCR org differs.
IMAGE_PREFIX=ghcr.io/baalvionservice/baalvion
IMAGE_TAG=prod-latest

# ── Domain + TLS ─────────────────────────────────────────────────────────────
DOMAIN=controlthemarket.com
# Email Let's Encrypt uses for cert expiry notices (Caddy ACME).
ACME_EMAIL=ops@baalvion.com

# ── Postgres (in-compose; swap to RDS by pointing DB_HOST at the RDS endpoint) ─
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password__
# ctm-service reads these (DB_HOST=postgres is the compose service name; for RDS use its host).
DB_HOST=postgres
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=__CHANGE_ME__strong_db_password__
# ── Database TLS (REQUIRED when DB_HOST points at RDS / any non-localhost Postgres) ──
# In-compose Postgres on the same host has no TLS → DB_SSL=false. For RDS set DB_SSL=true,
# keep cert verification on, and pin the RDS CA bundle.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA=<paste RDS CA bundle PEM, single line with \n escapes>
# ── RLS cutover (see Backend/docs/RLS-PRODUCTION-CUTOVER.md) ──
# ctm-service connects as the owner role above, which BYPASSES Postgres RLS. After verifying
# tenant isolation, point DB_USER at the non-superuser baalvion_app role so RLS enforces.
# Run migrations as POSTGRES_USER (owner) — they must bypass RLS.
# DB_USER=baalvion_app
# DB_PASSWORD=__CHANGE_ME__baalvion_app_password__

# ── App config ───────────────────────────────────────────────────────────────
NODE_ENV=production
# Only the public site origin in production — drop all localhost dev origins.
CORS_ORIGINS=https://controlthemarket.com
# Requests/min/IP for ctm-service's rate limiter.
RATE_LIMIT_IP_MAX=120

# ── Central SSO (auth) — the shared platform adapter ─────────────────────────
# CTM's backend VERIFIES login tokens; it does not mint them. Login/refresh proxy to the central
# identity (api.baalvion.com); ctm-service verifies the RS256 access token via @baalvion/auth-node —
# the same adapter every platform site uses.
#
# PREFERRED — JWKS (rotation-proof, nothing to paste): point at the central auth's public JWKS URL.
# auth-node fetches the current signing key (by `kid`) and caches it, so key rotation needs no
# redeploy. Confirm the exact public path returns {"keys":[...]} before go-live, e.g.:
#   curl -s https://api.baalvion.com/api/v1/identity/auth/.well-known/jwks.json
JWT_JWKS_URI=https://api.baalvion.com/api/v1/identity/auth/.well-known/jwks.json
# OPTIONAL fallback — a static PUBLIC key (single-line PEM, \n-escaped), used only if the JWKS
# endpoint is briefly unreachable. Leave blank to run JWKS-only. To set it:
#   awk 'NF {printf "%s\\n", $0}' <central-auth-public-key>.pem
JWT_PUBLIC_KEY=
# These MUST match the claims the central auth signs (defaults below are the platform standard).
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
# Where the frontend's /auth-bff/* is proxied (login/register/refresh). Point at the LIVE central
# auth endpoint. This is the proven default; change only if your central auth lives elsewhere.
AUTH_PROXY_TARGET=https://api.baalvion.com/api/v1/identity/auth/v1/auth

# ── Razorpay LIVE (real money) — handled by ctm-service directly, NO CMS vault ───────────────────
# From the Razorpay Dashboard (live mode). The webhook secret MUST equal the secret you set on the
# dashboard webhook pointing at https://${DOMAIN}/api/v1/payments/webhook
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=rzp_live___CHANGE_ME__
RAZORPAY_KEY_SECRET=__CHANGE_ME__
RAZORPAY_WEBHOOK_SECRET=__CHANGE_ME__dashboard_webhook_secret__
# Post-checkout redirect URLs (back into the app).
PAYMENT_SUCCESS_URL=https://controlthemarket.com/company/billing?paid=1
PAYMENT_CANCEL_URL=https://controlthemarket.com/company/billing?canceled=1

# ── Frontend build-time config (NEXT_PUBLIC_* are inlined into the client bundle at BUILD) ───────
# Same-origin: the browser calls https://controlthemarket.com/api/v1, Caddy routes /api/* → ctm-service.
NEXT_PUBLIC_CTM_API_URL=https://controlthemarket.com/api/v1
NEXT_PUBLIC_APP_URL=https://controlthemarket.com
# Mock auth is dev-only and MUST be false in production.
NEXT_PUBLIC_USE_MOCK=false
