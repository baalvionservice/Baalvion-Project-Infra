# ── deploy/jobs/.env.prod — STANDALONE jobs-service backend (option B) ──────────
# Copy to deploy/jobs/.env.prod and fill in. NEVER commit the real file (.env* is gitignored).
# Only needed if you run jobs-service OFF the consolidated box. Reuse the SAME secret values the
# consolidated box already uses (shared RDS + same RS256 issuer), so tokens + data line up.

# Edge / TLS
DOMAIN=jobs-api.baalvion.com
ACME_EMAIL=ops@baalvion.com

# Container image (same one-image backend artifact in ECR as the consolidated stack)
ECR_REGISTRY=__acct__.dkr.ecr.ap-south-1.amazonaws.com
IMAGE_TAG=prod-latest

# Database — shared AWS RDS (schema `jobs` is auto-created on boot). Use the SAME values as
# deploy/consolidated/.env so jobs writes to the same baalvion_db.
DB_HOST=__rds_endpoint__
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=__db_user__
DB_PASSWORD=__db_password__
DB_SSL=true

# Redis is on-box in this stack (service name `redis`).
REDIS_HOST=redis
REDIS_PORT=6379

# Browser origin allowed to call this API directly (the Vercel frontend).
CORS_ORIGINS=https://jobs.baalvion.com

# RS256 verification against the CENTRAL auth-service. PREFER the JWKS URI (live key rotation).
# Point it at the central auth's public JWKS (the auth.baalvion.com issuer).
BAALVION_JWKS_URI=https://auth.baalvion.com/.well-known/jwks.json
# Static fallback PEM (single line, \n-escaped) — same value as consolidated JWT_PUBLIC_KEY.
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# Object storage for resume/document uploads (OPTIONAL — uploads fail soft if blank).
S3_ENDPOINT=
S3_REGION=ap-south-1
S3_BUCKET=baalvion-prod-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# Email (application receipts) — OPTIONAL; reuse the central SES/SMTP creds if you want mail.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

RATE_LIMIT_IP_MAX=120
