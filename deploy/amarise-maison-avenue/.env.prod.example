# ─────────────────────────────────────────────────────────────────────────────
# Amarisé Maison Avenue — PRODUCTION secrets/config. Copy to `.env.prod` on the EC2
# host and fill EVERY __CHANGE_ME__. Never commit `.env.prod`.
#
#   cp deploy/amarise-maison-avenue/.env.prod.example deploy/amarise-maison-avenue/.env.prod
#   nano deploy/amarise-maison-avenue/.env.prod
#
# Generate strong secrets:   openssl rand -hex 32
# Generate the RS256 keypair (then single-line the PEMs — see JWT_* below):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt.key
#   openssl rsa -in jwt.key -pubout -out jwt.pub
#   # single-line a PEM for the env file (escape newlines as \n):
#   awk 'NF {printf "%s\\n", $0}' jwt.key   # → paste as JWT_PRIVATE_KEY
#   awk 'NF {printf "%s\\n", $0}' jwt.pub   # → paste as JWT_PUBLIC_KEY
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain + TLS ─────────────────────────────────────────────────────────────
DOMAIN=amarisemaisonavenue.com
ACME_EMAIL=__CHANGE_ME__ops@amarisemaisonavenue.com   # Let's Encrypt expiry notices
CORS_ORIGINS=https://amarisemaisonavenue.com,https://www.amarisemaisonavenue.com

# ── Postgres (in-compose; swap host to RDS later) ────────────────────────────
POSTGRES_DB=baalvion_db
POSTGRES_USER=baalvion
POSTGRES_PASSWORD=__CHANGE_ME__openssl_rand_hex_32__
DB_HOST=postgres
DB_PORT=5432
DB_SSL=false            # true when DB_HOST points at RDS with rds.force_ssl=1

# ── Redis (in-compose; swap host to ElastiCache later) ───────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT / identity (RS256). Single-line PEMs with \n escapes (see header). ────
JWT_PRIVATE_KEY=__CHANGE_ME__single_line_RS256_PRIVATE_PEM__
JWT_PUBLIC_KEY=__CHANGE_ME__single_line_RS256_PUBLIC_PEM__
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# ── Inter-service + CMS vault crypto secrets ─────────────────────────────────
INTERNAL_SERVICE_SECRET=__CHANGE_ME__openssl_rand_hex_32__
CMS_SECRETS_KEY=__CHANGE_ME__openssl_rand_hex_32__     # encrypts CMS vault (payment keys etc.)
RATE_LIMIT_IP_MAX=5000

# ── Super-admin (bootstrapped once; used to seed + manage content) ───────────
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=__CHANGE_ME__strong_password__

# ── Storefront build-time config (NEXT_PUBLIC_* are baked into the image) ────
# Active commerce store for Amarisé. Confirm against your commerce DB after seeding.
NEXT_PUBLIC_STORE_ID=a0a00000-0000-4000-8000-000000000001
NEXT_PUBLIC_CMS_WEBSITE_SLUG=amarise-maison-avenue
# Host that serves admin-uploaded product/editorial photos. Same domain by default
# (cms-service /uploads via /svc/cms); set to an S3/CloudFront host for scale.
NEXT_PUBLIC_MEDIA_HOST=amarisemaisonavenue.com
# Optional: central admin console URL for the /admin redirect.
NEXT_PUBLIC_ADMIN_CONSOLE_URL=
# Runtime: same-origin /auth-bff rewrite target (internal). Leave as-is for all-in-one.
AUTH_PROXY_TARGET=http://auth-service:3001/v1/auth

# ── Consumer social login (Google / Facebook OAuth) ──────────────────────────
# Read by auth-service (docker-compose passes these into its environment). The
# provider redirects the BROWSER to https://<DOMAIN>/auth-bff/oauth/<provider>/callback,
# so register THAT exact URL in each provider console. OAUTH_PUBLIC_BASE_URL / OAUTH_APP_URL
# / AUTH_SITE_SLUG already default to the domain/slug in the compose file — only the
# client credentials below need filling (or manage them in the admin panel → CMS vault,
# in which case leave these blank; the buttons degrade to "not available" until set).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# ── Payments (KEYS AT GO-LIVE) ───────────────────────────────────────────────
# Launch the storefront with PAYMENTS_MOCK=true (checkout auto-confirms, no real charge),
# then drop in real keys for the provider(s) you use and set PAYMENTS_MOCK=false.
# See GO-LIVE.md for webhook setup.
PAYMENTS_MOCK=true
# Razorpay (IN/AE strong; per-txn amount caps can block very high-value luxury items)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Stripe (US/UK/EU/luxury — hosted Checkout)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# PayU (optional)
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# ── Transactional email (password reset, order confirmation) — e.g. AWS SES ──
EMAIL_FROM=noreply@amarisemaisonavenue.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Product-catalog seed (one-time, set automatically by init-data.sh) ───────
# init-data.sh fills AMARISE_ORG_ID / AMARISE_OWNER_ID from the bootstrapped super-admin
# so the seeded store is owned by the prod org. Set SEED_MEDIA_BASE_URL to your photo CDN
# (files named <product-slug>-1.jpg …) to ship with real photography; leave blank to launch
# with branded placeholder panels and add photos later via the admin.
AMARISE_ORG_ID=
AMARISE_OWNER_ID=
SEED_MEDIA_BASE_URL=

# ── Container image registry (only if pulling prebuilt images; default builds locally) ─
IMAGE_PREFIX=baalvion
IMAGE_TAG=prod-latest
NODE_ENV=production
