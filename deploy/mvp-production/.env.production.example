# ============================================================================
# Baalvion MVP — .env.production  (copy to .env.production, fill, NEVER commit)
# Values marked 🔒 belong in AWS Secrets Manager; the rest are configuration.
# ============================================================================

# ---- image tag --------------------------------------------------------------
IMAGE_TAG=prod-latest

# ---- domains ----------------------------------------------------------------
DOMAIN_API=api.baalvion.com
DOMAIN_ADMIN=admin.baalvion.com
DOMAIN_WEB=baalvion.com
DOMAIN_SHOP=shop.baalvion.com
ACME_EMAIL=infra.baalvion@gmail.com
CORS_ORIGINS=https://baalvion.com,https://admin.baalvion.com,https://shop.baalvion.com
API_BASE_URL=https://api.baalvion.com
CMS_BASE_URL=http://cms-service:3018

# ---- RDS PostgreSQL (managed) ----------------------------------------------
DB_HOST=baalvion-prod.xxxxxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion              # owner/migration role
DB_PASSWORD=                  # 🔒
DB_SSL=require
# payment-service runtime (non-superuser RLS role)
DB_APP_USER=baalvion_app
DB_APP_PASSWORD=              # 🔒
DB_JDBC_PARAMS=?sslmode=require

# ---- ElastiCache Redis (managed) -------------------------------------------
REDIS_HOST=baalvion-prod.xxxxxx.ng.0001.aps1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=               # 🔒 (AUTH token; blank if disabled)

# ---- JWT / RS256 ------------------------------------------------------------
# Single-line PEM with \n escapes. Generate with pnpm run generate:keys.
JWT_PRIVATE_KEY=              # 🔒  auth-service only
JWT_PUBLIC_KEY=               #     all verifying services
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_ACCESS_SECRET=            # 🔒  >=48 bytes base64
JWT_REFRESH_SECRET=           # 🔒  >=48 bytes base64

# ---- inter-service secrets --------------------------------------------------
GATEWAY_SIGNING_SECRET=       # 🔒  >=32 chars (auth-gateway fail-closed)
INTERNAL_SERVICE_SECRET=      # 🔒  shared HMAC (cms/order/notification/payment)
RBAC_INTERNAL_API_KEY=        # 🔒  rbac <-> commerce/order
INVENTORY_INTERNAL_KEY=       # 🔒  inventory <-> order (must match on both)
AUDIT_INTERNAL_KEY=           # 🔒
CART_SESSION_SECRET=          # 🔒  order-service guest carts (blank disables them)
CMS_SECRETS_KEY=              # 🔒  encrypts CMS payment-key vault

# ---- superadmin bootstrap ---------------------------------------------------
SUPERADMIN_EMAIL=superadmin@baalvion.com
SUPERADMIN_PASSWORD=          # 🔒  rotate immediately after first login

# ---- S3 (media: cms + commerce) --------------------------------------------
AWS_REGION=ap-south-1
S3_ENDPOINT=                  # blank for AWS S3
S3_BUCKET=baalvion-media-prod
S3_REGION=ap-south-1
S3_ACCESS_KEY=                # 🔒  (prefer IAM role on EC2/ECS over static keys)
S3_SECRET_KEY=                # 🔒
S3_PUBLIC_URL=https://baalvion-media-prod.s3.ap-south-1.amazonaws.com

# ---- Email via Amazon SES (SMTP interface) ---------------------------------
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=                    # 🔒  SES SMTP username
SMTP_PASS=                    # 🔒  SES SMTP password
EMAIL_FROM=noreply@baalvion.com

# ---- Razorpay (production) --------------------------------------------------
# These keys feed BOTH the storefront path (order-service, which captures Razorpay
# directly) and the Java payment-service gateway. order-service prefers per-site keys
# from the CMS vault and falls back to these env values.
RAZORPAY_KEY_ID=              # 🔒  rzp_live_xxx
RAZORPAY_KEY_SECRET=          # 🔒
RAZORPAY_WEBHOOK_SECRET=      # 🔒  set in Razorpay dashboard webhook config (same value here)
RAZORPAY_BASE_URL=https://api.razorpay.com

# ---- storefront -------------------------------------------------------------
AMARISE_STORE_ID=             # commerce store UUID created during seeding (BAKED into amarise-web at build)
AMARISE_CMS_SLUG=amarise-maison-avenue   # CMS website slug = order-service PAYMENT_SITE_SLUG (vault lookup)
AMARISE_MEDIA_HOST=           # S3/CloudFront host serving product images (e.g. media.baalvion.com).
                              # BAKED into amarise-web for next/image remotePatterns + image CSP.
                              # Leave blank only if product images are served same-origin.
