# Baalvion code ownership — routes PR reviews to the owning team per bounded
# context. Enforced via branch protection (required review from code owners).
# A change to another context's contract REQUIRES that context's team approval —
# this is how bounded-context boundaries are enforced in code review.
# Teams are defined in the GitHub org; mirror them in catalog/services/*.yaml `owner`.
#
# Paths follow the federated layout: Backend/services/<domain>/<service>.

# ── Default ──────────────────────────────────────────────────────────────────
*                                               @baalvion/platform-core

# ── Shared platform packages (changes ripple everywhere — extra scrutiny) ──────
/Backend/packages/                              @baalvion/platform-core
/Backend/packages/contracts/                    @baalvion/platform-core @baalvion/architecture
/Backend/packages/events/                       @baalvion/platform-core @baalvion/architecture
/Backend/packages/auth-node/                    @baalvion/platform-core @baalvion/security-team
/Backend/packages/auth-sdk/                     @baalvion/platform-core
/Backend/packages/rbac/                         @baalvion/platform-core @baalvion/security-team
/Backend/packages/security/                     @baalvion/security-team
/Backend/packages/crypto/                       @baalvion/security-team
/Backend/packages/telemetry/                    @baalvion/observability

# ── Contracts are co-owned by producer + architecture (breaking-change gate) ───
/Backend/packages/contracts/proto/baalvion/identity/   @baalvion/platform-core @baalvion/architecture
/Backend/packages/contracts/proto/baalvion/billing/    @baalvion/commerce-division @baalvion/architecture
/Backend/packages/contracts/proto/baalvion/proxy/      @baalvion/proxy-division @baalvion/architecture

# ── Identity domain (auth foundation) ──────────────────────────────────────────
/Backend/services/identity/                     @baalvion/platform-core @baalvion/security-team

# ── Platform domain (admin / dashboard / realtime) ─────────────────────────────
/Backend/services/platform/                     @baalvion/platform-core

# ── Commerce domain ─────────────────────────────────────────────────────────
/Backend/services/commerce/                     @baalvion/commerce-division
/Backend/services/commerce/financial-services-java/  @baalvion/commerce-division @baalvion/architecture

# ── Knowledge domain (cms / imperialpedia / law / ml) ──────────────────────────
/Backend/services/knowledge/                    @baalvion/knowledge-division
/Backend/services/knowledge/ml-service/         @baalvion/data-platform @baalvion/knowledge-division

# ── Ecosystem domain (vertical apps' backends) ─────────────────────────────────
/Backend/services/ecosystem/                    @baalvion/ecosystem-division
/Backend/services/ecosystem/law-elite/          @baalvion/legal-division
/Backend/services/ecosystem/real-estate-service/ @baalvion/real-estate-division
/Backend/services/ecosystem/mining-service/     @baalvion/mining-division
/Backend/services/ecosystem/jobs-service/       @baalvion/jobs-division

# ── Infrastructure domain (proxy / notifications / realtime) ───────────────────
/Backend/services/infrastructure/               @baalvion/sre @baalvion/platform-core
/Backend/services/infrastructure/proxy-service/ @baalvion/proxy-division

# ── Cross-cutting infrastructure ───────────────────────────────────────────────
/Backend/gateway/                               @baalvion/proxy-division @baalvion/platform-core
/Backend/database/                              @baalvion/platform-core @baalvion/sre
/Backend/infra/                                 @baalvion/sre
/Backend/catalog/                               @baalvion/architecture
/Backend/platform/cli/                          @baalvion/platform-core

# ── Frontend applications ──────────────────────────────────────────────────────
