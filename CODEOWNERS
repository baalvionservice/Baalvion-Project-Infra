# Baalvion code ownership — routes PR reviews to the owning team per bounded
# context. Enforced via branch protection (required review from code owners).
# A change to another context's contract REQUIRES that context's team approval —
# this is how bounded-context boundaries are enforced in code review.
# Teams are defined in the GitHub org; mirror them in catalog/services/*.yaml `owner`.

# ── Default ──────────────────────────────────────────────────────────────────
*                                       @baalvion/platform-core

# ── Shared platform packages (changes ripple everywhere — extra scrutiny) ──────
/Backend/packages/                              @baalvion/platform-core
/Backend/packages/contracts/                    @baalvion/platform-core @baalvion/architecture
/Backend/packages/events/                       @baalvion/platform-core @baalvion/architecture
/Backend/packages/auth-sdk/                     @baalvion/platform-core
/Backend/packages/rbac/                         @baalvion/platform-core
/Backend/packages/telemetry/                    @baalvion/observability

# ── Contracts are co-owned by producer + architecture (breaking-change gate) ───
/Backend/packages/contracts/proto/baalvion/identity/   @baalvion/platform-core @baalvion/architecture
/Backend/packages/contracts/proto/baalvion/billing/    @baalvion/platform-core @baalvion/architecture
/Backend/packages/contracts/proto/baalvion/proxy/      @baalvion/proxy-division @baalvion/architecture

