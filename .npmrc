# Mixed-engine monorepo: backend services target Node 20 (node:20-alpine images),
# while some frontend deps declare engines.node >=22. engine-strict=true makes the
# whole `pnpm install` fail on Node 20; we warn instead of blocking. (Build model: Option A.)
engine-strict=false
auto-install-peers=true
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=rolling
shamefully-hoist=false
strict-peer-dependencies=false
