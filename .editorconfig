# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,mjs,cjs,json,yml,yaml,css,scss,html,md}]
indent_style = space
indent_size = 2

[*.{py,java}]
indent_size = 4

[*.go]
indent_style = tab

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{ps1,psm1}]
end_of_line = crlf
