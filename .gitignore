# ──────────────────────────────────────────────
# Environment / Secrets — NEVER commit
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
# Exception: the Terraform "secrets" MODULE is IaC (resource definitions referencing
# variables), not actual secret material — keep it tracked.
!Backend/infra/terraform/modules/secrets/
!Backend/infra/terraform/modules/secrets/**
credentials.json
service-account.json
# Local env backups & editor cruft (Phase 0 cleanup — keep these out of the tree)
*.bak
*.old

# ──────────────────────────────────────────────
# Node / Package managers
# ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ──────────────────────────────────────────────
# Build outputs
# ──────────────────────────────────────────────
dist/
build/
.next/
.turbo/
out/
*.tsbuildinfo

# ──────────────────────────────────────────────
# Test / Coverage
# ──────────────────────────────────────────────
coverage/
playwright-report/
test-results/
.nyc_output/
*.lcov
.lighthouseci/

# ──────────────────────────────────────────────
# OS / Editor
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
# …but Next.js App Router route segments may legitimately be named "logs"
# (e.g. /notifications/logs) — those are source, not log output.
!**/src/app/**/logs/
!**/src/app/**/logs/**
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ──────────────────────────────────────────────
# Docker / Infra
# ──────────────────────────────────────────────
docker-compose.override.yml
*.tfstate
*.tfstate.backup
.terraform/
terraform.tfvars

# ──────────────────────────────────────────────
# Uploads / Generated files
# ──────────────────────────────────────────────
uploads/
public/uploads/
*.sqlite
*.db

# key-extraction utility lives in the secrets dir; do not track
make_keys.cjs

# ──────────────────────────────────────────────
# Local scratch / dev artifacts — do not commit
# ──────────────────────────────────────────────
.devlogs/
/*.out.json
/snapshot_*.sql
/backend-tree-*.txt
/_echo.js
/_lawyer_dash*.png
*.tmp

# ── Local IDE / harness / transient dumps — never commit ──
.vs/
.claude/
.dep-err.txt
.dependabot-alerts.json
REPOSITORY_INVENTORY.md

# Local screenshot dumps + capture scripts (binary/local artifacts — never commit)
assets/.*

# Database backups (may contain PII / real data — never commit)
backups/
*.dump
*.sql.gz
.aider*

# Reports
Reports/
build-report.txt
lint-report.txt

# Generic cache
.cache/

# scratch artifacts (do not commit)
PROJECT_STRUCTURE.txt
error-report.json
error-report.txt
.audit_*.json
.audit_*.json
.audit_*.json

# security-alert exports (regenerable; never commit alert data)
_codeql_alerts.json
_dependabot_alerts.json
