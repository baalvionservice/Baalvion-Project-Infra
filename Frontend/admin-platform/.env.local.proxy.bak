# ── Admin Platform — LOCAL "production-like" wiring (served at admin.baalvion.local) ──
# The reverse proxy serves this app AND fronts the whole backend fleet on the SAME
# origin under /__api/<service>/*. Every browser call is same-origin → no CORS, no
# mixed-content, HTTPS-ready. NEXT_PUBLIC_* is inlined at build time → rebuild after
# changes. Revert with .env.local.localhost.bak.

# Auth: same-origin /auth-bff rewrite (next.config.ts) → local auth-service.
# Server-side target → stays on localhost.
AUTH_PROXY_TARGET=http://localhost:3001/v1/auth
NEXT_PUBLIC_AUTH_URL=http://localhost:3001/v1/auth

# ── Named identity/CMS clients (src/lib/api/client.ts) — same-origin gateway ──
NEXT_PUBLIC_ADMIN_API_URL=http://admin.baalvion.local/__api/admin/v1
NEXT_PUBLIC_CMS_API_URL=http://admin.baalvion.local/__api/cms/api/v1
NEXT_PUBLIC_SESSION_API_URL=http://admin.baalvion.local/__api/session/v1
NEXT_PUBLIC_OAUTH_URL=http://admin.baalvion.local/__api/oauth
NEXT_PUBLIC_API_URL=http://admin.baalvion.local/__api/proxy/v1

# Realtime metrics WebSocket (realtime-service :3026). Direct ws:// in the HTTP tier;
# for the HTTPS/Caddy tier change to wss://admin.baalvion.local/__api/realtime/...
NEXT_PUBLIC_WS_URL=ws://localhost:3026/api/v1/infrastructure/realtime

# ── Per-service clients (serviceClients factory) — SERVICE_URL_MAP override ──
# JSON: service name → same-origin gateway base URL (path after /__api/<name> is
# forwarded verbatim, so each base carries the service's real mount path).
NEXT_PUBLIC_SERVICE_URLS={"jobs":"http://admin.baalvion.local/__api/jobs/api/v1","mining":"http://admin.baalvion.local/__api/mining/api/v1","imperialpedia":"http://admin.baalvion.local/__api/imperialpedia/api/v1","realEstate":"http://admin.baalvion.local/__api/realEstate/api/v1","brand":"http://admin.baalvion.local/__api/brand/api/v1","market":"http://admin.baalvion.local/__api/market/api/v1","ir":"http://admin.baalvion.local/__api/ir/api/v1","dashboard":"http://admin.baalvion.local/__api/dashboard/api/v1","about":"http://admin.baalvion.local/__api/about/api/v1","ctm":"http://admin.baalvion.local/__api/ctm/api/v1","commerce":"http://admin.baalvion.local/__api/commerce/api/v1","orders":"http://admin.baalvion.local/__api/orders/api/v1","inventory":"http://admin.baalvion.local/__api/inventory/api/v1","fulfillment":"http://admin.baalvion.local/__api/fulfillment/api/v1","law":"http://admin.baalvion.local/__api/law/v1","rbac":"http://admin.baalvion.local/__api/rbac/api/v1","audit":"http://admin.baalvion.local/__api/audit/v1","notifications":"http://admin.baalvion.local/__api/notifications/v1"}

NEXT_PUBLIC_APP_URL=http://admin.baalvion.local
NEXT_PUBLIC_APP_NAME=Baalvion Admin
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ACCESS_TOKEN_TTL=900000
