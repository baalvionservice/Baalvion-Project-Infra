# ─────────────────────────────────────────────────────────────────────────────
# admin-platform — PRODUCTION env reference (admin.baalvion.com on Vercel)
#
# Copy these into Vercel → Project → Settings → Environment Variables (Production).
# All URLs route through the single public Traefik ingress (api.baalvion.com),
# per Backend/infra/api-gateway/dynamic.yml. Path convention:
#   https://api.baalvion.com/api/v1/<domain>/<service> + the service's mount path
#
# Do NOT copy .env.local here — those localhost values only work in dev.
# The core API vars below already have production-correct fallbacks baked into
# src/lib/api/client.ts; they are listed explicitly for clarity/overridability.
# ─────────────────────────────────────────────────────────────────────────────

# ── App identity ──
NEXT_PUBLIC_APP_URL=https://admin.baalvion.com
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_NAME=Baalvion Admin
NEXT_PUBLIC_ACCESS_TOKEN_TTL=900000

# ── Gateway + core identity / admin / CMS ──
NEXT_PUBLIC_GATEWAY_URL=https://api.baalvion.com
NEXT_PUBLIC_API_URL=https://api.baalvion.com/api/v1/infrastructure/proxy/v1
# Same-origin BFF: the browser hits admin.baalvion.com/api-bff/<domain>/<service>/*, which
# the box's Caddy terminates → the right service container. The api.baalvion.com/api/v1/*
# paths do NOT route to these services (the public edge BFF only carves out CMS-public +
# payments → 404 "Route not found"). Do NOT revert these to api.baalvion.com.
NEXT_PUBLIC_ADMIN_API_URL=https://admin.baalvion.com/api-bff/platform/admin/v1
NEXT_PUBLIC_SESSION_API_URL=https://admin.baalvion.com/api-bff/identity/session/v1
NEXT_PUBLIC_OAUTH_URL=https://admin.baalvion.com/api-bff/identity/oauth
NEXT_PUBLIC_CMS_API_URL=https://admin.baalvion.com/api-bff/knowledge/cms/api/v1

# ── Auth (server-side rewrite target in next.config.ts; default already equals this) ──
AUTH_PROXY_TARGET=https://api.baalvion.com/api/v1/identity/auth/v1/auth

# ── Realtime metrics (WebSocket). Verify the path against realtime-service once live. ──
NEXT_PUBLIC_WS_URL=wss://api.baalvion.com/api/v1/infrastructure/realtime

# ── Per-domain service clients ──────────────────────────────────────────────
# Each entry = gateway namespace (/api/v1/<domain>/<service>) + the service's
# own mount path (/api/v1 for most, /v1 for law/audit/notifications). Verified
# against dynamic.yml routers. `orders` is intentionally OMITTED — order-service
# is deprecated (lifecycle moved to the trade domain's order-execution-service);
# the admin `orders` client must be repointed there before those pages work.
# rbac / audit / crm were added to dynamic.yml alongside this file.
NEXT_PUBLIC_SERVICE_URLS={"jobs":"https://admin.baalvion.com/api-bff/ecosystem/jobs/api/v1","mining":"https://admin.baalvion.com/api-bff/ecosystem/mining/api/v1","imperialpedia":"https://admin.baalvion.com/api-bff/knowledge/imperialpedia/api/v1","realEstate":"https://admin.baalvion.com/api-bff/ecosystem/real-estate/api/v1","brand":"https://admin.baalvion.com/api-bff/ecosystem/brand-connector/api/v1","market":"https://admin.baalvion.com/api-bff/commerce/market/api/v1","ir":"https://admin.baalvion.com/api-bff/ecosystem/ir/api/v1","dashboard":"https://admin.baalvion.com/api-bff/platform/dashboard/api/v1","about":"https://admin.baalvion.com/api-bff/ecosystem/about/api/v1","ctm":"https://admin.baalvion.com/api-bff/ecosystem/ctm/api/v1","commerce":"https://admin.baalvion.com/api-bff/commerce/commerce/api/v1","inventory":"https://admin.baalvion.com/api-bff/commerce/inventory/api/v1","fulfillment":"https://admin.baalvion.com/api-bff/commerce/fulfillment/api/v1","law":"https://admin.baalvion.com/api-bff/knowledge/law/v1","notifications":"https://admin.baalvion.com/api-bff/infrastructure/notification/v1","rbac":"https://admin.baalvion.com/api-bff/identity/rbac/api/v1","audit":"https://admin.baalvion.com/api-bff/infrastructure/audit/v1","crm":"https://admin.baalvion.com/api-bff/ecosystem/crm/api/v1"}

# ── CRM (separate single-service var; same-origin /api-bff like the rest) ──
NEXT_PUBLIC_CRM_API_URL=https://admin.baalvion.com/api-bff/ecosystem/crm/api/v1
