# ── Admin Platform — LOCAL DEV wiring (core identity slice) ──────────────────
# Auth flows through the same-origin /auth-bff rewrite (next.config.ts) so the
# httpOnly refresh cookie is stored against this origin. Point it at local auth-service.
AUTH_PROXY_TARGET=http://localhost:3001/v1/auth

# Identity admin domain — admin-service (real backend, raw SQL over auth.*)
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3021/v1

# CMS engine — cms-service (multi-site content/taxonomy/media/workflow)
NEXT_PUBLIC_CMS_API_URL=http://localhost:3011/api/v1
NEXT_PUBLIC_SESSION_API_URL=http://localhost:3022/v1
NEXT_PUBLIC_OAUTH_URL=http://localhost:3023

# Realtime metrics + event fan-out (realtime-service WebSocket + REST snapshot)
NEXT_PUBLIC_WS_URL=ws://localhost:3026/api/v1/infrastructure/realtime

# Generic gateway for non-identity domains (not required for the core slice).
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_AUTH_URL=http://localhost:3001/v1/auth

NEXT_PUBLIC_APP_URL=http://localhost:3030
NEXT_PUBLIC_APP_NAME=Baalvion Admin
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ACCESS_TOKEN_TTL=900000
