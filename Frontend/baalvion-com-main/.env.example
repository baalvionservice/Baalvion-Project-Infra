# baalvion-com-web — build-time env for the static export.
# Cloudflare Worker vars (AUTH_SERVICE_URL) live in wrangler.jsonc / `wrangler secret`, NOT here.

# Cloudflare Turnstile site key for the embedded /signin form. Inlined at build time.
# Leave empty for local preview (captcha skipped); SET in production builds.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
