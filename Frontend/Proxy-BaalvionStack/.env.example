# Proxy-BaalvionStack — Environment Variables
# Copy to .env.local (Vite) and fill in values.

# Auth microservice (baalvion auth-service)
VITE_API_AUTH_BASE_URL=http://localhost:3001/v1/auth

# Shared Baalvion sign-in surface (auth.baalvion.com). The primary "Sign In" delegates here.
VITE_AUTH_URL=https://auth.baalvion.com

# Platform + Admin API (proxy-backend)
VITE_API_PLATFORM_BASE_URL=http://localhost:4000/v1

# App metadata
VITE_APP_URL=http://localhost:8080

# Proxy gateway (Go data plane) — shown on the Proxy Access page
VITE_PROXY_GATEWAY_HOST=gw.baalvion.net
VITE_PROXY_GATEWAY_HTTP_PORT=10000
VITE_PROXY_GATEWAY_SOCKS_PORT=1080
# Single API gateway ingress (repair: frontend -> gateway -> services). Override for local.
VITE_GATEWAY_URL=https://api.baalvion.com
