{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "ignoreCommand": "npx turbo-ignore proxy-baalvionstack-web",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm exec turbo run build --filter=proxy-baalvionstack-web",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
