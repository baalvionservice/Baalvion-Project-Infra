
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().roleId == role;
    }

    function isActive() {
      return isAuthenticated() && getUserData().profileStatus == 'active';
    }

    // Checks if the user is either the client or the assigned lawyer for a case
    function isCaseParticipant(caseData) {
      return request.auth.uid == caseData.clientId || request.auth.uid == caseData.assignedLawyerId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }

    match /lawyer_profiles/{userId} {
      allow read: if (resource.data.verificationStatus == 'approved' && resource.data.profileStatus == 'active') || isOwner(userId) || hasRole('admin');
      allow write: if isOwner(userId) || hasRole('admin');
    }

    match /client_profiles/{userId} {
      allow read: if isOwner(userId) || hasRole('admin');
      allow write: if isOwner(userId) || hasRole('admin');
    }

    match /cases/{caseId} {
      allow read: if isAuthenticated() && (isCaseParticipant(resource.data) || hasRole('admin'));
      allow create: if hasRole('client') && isActive();
      allow update: if isAuthenticated() && (isCaseParticipant(resource.data) || hasRole('admin'));
      allow delete: if hasRole('admin'); // Only admins can hard delete, others soft-delete (update)
    }

    match /documents/{docId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.uploadedBy || 
        request.auth.uid == get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId ||
        request.auth.uid == get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.assignedLawyerId ||
        hasRole('admin')
      );
      allow create: if isAuthenticated() && isActive();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.uploadedBy || hasRole('admin'));
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || hasRole('admin'));
      allow create: if isAuthenticated() && isActive();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.clientUid || request.auth.uid == resource.data.lawyerUid || hasRole('admin'));
      allow create: if hasRole('client') && isActive();
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.clientUid || request.auth.uid == resource.data.lawyerUid || hasRole('admin'));
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.clientId ||
        request.auth.uid == get(/databases/$(database)/documents/cases/$(resource.data.caseId)).data.assignedLawyerId ||
        hasRole('admin')
      );
      allow create: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }
  }
}
