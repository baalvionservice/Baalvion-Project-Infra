
{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "Primary legal domains",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "slug", "isActive"]
    },
    "Subcategory": {
      "title": "Subcategory",
      "description": "Specific topics within a legal domain",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "categoryId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "categoryId", "name", "slug", "isActive"]
    },
    "Article": {
      "title": "Article",
      "description": "Core educational content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "categoryId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "content": { "type": "string", "description": "Rich HTML string" },
        "summary": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isPillar": { "type": "boolean" },
        "alphabet": { "type": "string" },
        "readingTime": { "type": "number" },
        "views": { "type": "number" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "slug", "categoryId", "subcategoryId"]
    },
    "KeywordMapping": {
      "title": "KeywordMapping",
      "description": "Rules for automated internal linking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "keyword": { "type": "string" },
        "targetSlug": { "type": "string" },
        "priorityScore": { "type": "number" },
        "categoryContext": { "type": "string" }
      },
      "required": ["id", "keyword", "targetSlug"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "#/backend/entities/Category",
      "description": "Root legal domains"
    },
    "/subcategories/{subcategoryId}": {
      "schema": "#/backend/entities/Subcategory",
      "description": "Specialized topics mapped to categories"
    },
    "/articles/{articleId}": {
      "schema": "#/backend/entities/Article",
      "description": "Legal knowledge articles"
    },
    "/keyword_mappings/{mappingId}": {
      "schema": "#/backend/entities/KeywordMapping",
      "description": "Automated internal linking rules"
    }
  }
}
