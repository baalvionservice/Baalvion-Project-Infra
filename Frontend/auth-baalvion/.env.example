# ── auth-baalvion (auth.baalvion.com) ───────────────────────────────────────────
# The internal auth-service base the BFF proxies to. In Docker use the service name; locally the
# dev port. The browser only ever sees the same-origin /auth-bff/* path.
AUTH_SERVICE_URL=http://auth-service:3001

# Cloudflare Turnstile (public site key for the widget). The matching TURNSTILE_SECRET_KEY lives on
# the auth-service. When unset, the captcha is skipped (local dev) — keep it SET in production.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Extra (non-baalvion.com) hostnames allowed as a return_to target, comma-separated. *.baalvion.com
# and a baseline of known apex domains are always allowed; add others here as sites are wired in.
# e.g. amarisemaisonavenue.com,baalvionstack.com,controlthemarket.com
NEXT_PUBLIC_ALLOWED_RETURN_HOSTS=
