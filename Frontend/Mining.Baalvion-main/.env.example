# ─────────────────────────────────────────────────────────────────────────────
# Baalvion Mining Inc. — environment configuration
# Copy to `.env.local` and fill in real values. NEXT_PUBLIC_* are exposed to the
# browser; everything else is server-only. Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App / public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3028

# ── Backend service endpoints (server + public mix, per existing app) ─────────
NEXT_PUBLIC_MINING_API_URL=http://localhost:3003
NEXT_PUBLIC_AUTH_URL=http://localhost:4000/v1/auth
NEXT_PUBLIC_API_BASE_URL=http://localhost:3003/api
# Same-origin auth proxy target (see next.config.ts rewrites)
AUTH_PROXY_TARGET=https://api.baalvion.com/api/v1/identity/auth/v1/auth

# ── Analytics (BLOCKER: set a real GA4 id to enable analytics) ────────────────
# Leave blank or as the placeholder to keep GA disabled. The GoogleAnalytics
# component only loads gtag when a real id (not G-XXXXXXXXXX) is present.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Central CMS (Trade Insights / blog content) ──────────────────────────────
CMS_PUBLIC_URL=http://localhost:3018/api/v1/public
CMS_WEBSITE_SLUG=baalvion-mining
NEXT_PUBLIC_CMS_CONSOLE_URL=

# ── Outbound email for form submissions (BLOCKER: wire a provider) ────────────
# Used by src/lib/email.ts. If EMAIL_PROVIDER is unset, submissions are still
# accepted and logged (queued) — they are never lost — but no email is sent.
# EMAIL_PROVIDER=smtp | resend | ses
EMAIL_PROVIDER=
# Destination inboxes (optional overrides; defaults are baked into the routes)
CONTACT_INBOX=trade@baalvion.com
PARTNERSHIP_INBOX=partnerships@baalvion.com
# Provider credentials — set only the block matching EMAIL_PROVIDER:
SMTP_URL=
RESEND_API_KEY=
AWS_REGION=

# ── Admin content API (BLOCKER: set before enabling CMS writes) ───────────────
# Bearer token guarding the /api/* write endpoints (src/lib/api/admin-guard.ts).
# Placeholder for real session/RBAC auth — see docs/PLATFORM_ARCHITECTURE.md.
ADMIN_API_TOKEN=
