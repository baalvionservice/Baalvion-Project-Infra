
{
  "entities": {
    "SubscriptionPlan": {
      "title": "Subscription Plan",
      "description": "Definition of a platform membership tier.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "priceMonthly": { "type": "number" },
        "priceAnnual": { "type": "number" },
        "features": { "type": "array", "items": { "type": "string" } },
        "transactionFeeRate": { "type": "number" },
        "isActive": { "type": "boolean" }
      }
    },
    "UserSubscription": {
      "title": "User Subscription",
      "description": "The active billing status for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "PAST_DUE", "CANCELED", "TRIAL"] },
        "currentPeriodEnd": { "type": "string", "format": "date-time" },
        "cancelAtPeriodEnd": { "type": "boolean" }
      }
    },
    "AdCampaign": {
      "title": "Advertising Campaign",
      "description": "Record of a promotional placement purchased by a supplier.",
      "type": "object",
      "properties": {
        "advertiserId": { "type": "string" },
        "type": { "type": "string", "enum": ["FEATURED_LISTING", "BANNER", "SPONSORED_PROFILE"] },
        "status": { "type": "string", "enum": ["PENDING", "ACTIVE", "EXPIRED", "REJECTED"] },
        "targetId": { "type": "string", "description": "ID of product or profile being promoted." },
        "budget": { "type": "number" },
        "startsAt": { "type": "string", "format": "date-time" },
        "endsAt": { "type": "string", "format": "date-time" },
        "metrics": {
          "type": "object",
          "properties": {
            "impressions": { "type": "number" },
            "clicks": { "type": "number" }
          }
        }
      }
    },
    "CommissionRecord": {
      "title": "Trade Commission",
      "description": "Record of platform revenue collected from a finalized trade.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "default": "USD" },
        "status": { "type": "string", "enum": ["PENDING", "COLLECTED", "REFUNDED"] },
        "collectedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemMetric": {
      "title": "System Performance Metric",
      "description": "Telemetery data for regional node health and latency.",
      "type": "object",
      "properties": {
        "nodeId": { "type": "string" },
        "type": { "type": "string", "enum": ["LATENCY", "CPU", "MEMORY", "CACHE_HIT_RATE"] },
        "value": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AsyncJob": {
      "title": "Asynchronous Process Job",
      "description": "Tracking record for background tasks like report generation or global RFQ matching.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["REPORT_GEN", "RFQ_MATCH", "DOC_VERIFY"] },
        "status": { "type": "string", "enum": ["QUEUED", "RUNNING", "COMPLETED", "FAILED"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "actorId": { "type": "string" },
        "payload": { "type": "object" },
        "resultUrl": { "type": "string" },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ApiEndpoint": {
      "title": "API Endpoint Definition",
      "description": "Registry of internal and external API endpoints managed by the platform.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "version": { "type": "string" },
        "type": { "type": "string", "enum": ["INTERNAL", "PARTNER", "SYSTEM"] },
        "status": { "type": "string", "enum": ["ACTIVE", "DEPRECATED", "RETIRED"] },
        "latencyAvg": { "type": "number", "description": "Rolling average response time in ms." },
        "errorRate": { "type": "number" }
      }
    },
    "ExternalIntegration": {
      "title": "Third-Party Integration",
      "description": "Configuration and status for external service connections (Logistics, Payment, AI).",
      "type": "object",
      "properties": {
        "serviceName": { "type": "string" },
        "category": { "type": "string", "enum": ["PAYMENT", "LOGISTICS", "AI", "MARKET_DATA"] },
        "status": { "type": "string", "enum": ["ONLINE", "OFFLINE", "DEGRADED", "MAINTENANCE"] },
        "baseUrl": { "type": "string" },
        "lastSuccess": { "type": "string", "format": "date-time" },
        "healthScore": { "type": "number", "minimum": 0, "maximum": 100 }
      },
      "required": ["serviceName", "category", "status"]
    },
    "ApiAccessLog": {
      "title": "API Access Log",
      "description": "Detailed request log for performance monitoring and auditing.",
      "type": "object",
      "properties": {
        "endpointId": { "type": "string" },
        "actorId": { "type": "string" },
        "ipAddress": { "type": "string" },
        "statusCode": { "type": "number" },
        "responseTime": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ApiKeyRecord": {
      "title": "API Key Management",
      "description": "Records of issued API keys for third-party partners.",
      "type": "object",
      "properties": {
        "partnerId": { "type": "string" },
        "keyAlias": { "type": "string" },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "lastUsedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DashboardConfig": {
      "title": "Dashboard Configuration",
      "description": "User-specific or role-specific layout settings for the dashboard interface.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "visibleWidgets": { "type": "array", "items": { "type": "string" } },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "isSidebarCollapsed": { "type": "boolean" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "A user-initiated request for assistance or technical support.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "status": { "type": "string", "enum": ["OPEN", "IN_PROGRESS", "AWAITING_USER", "RESOLVED", "CLOSED"] },
        "category": { "type": "string", "enum": ["TECHNICAL", "FINANCE", "TRADE", "ACCOUNT"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "status"]
    },
    "Country": {
      "title": "Country Registry",
      "description": "Global country data including trade regions and export eligibility.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "region": { "type": "string", "enum": ["Africa", "Asia Pacific", "South America", "North America", "Europe", "Middle East"] },
        "isExportEligible": { "type": "boolean" },
        "restrictedMinerals": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["code", "name", "region"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "A real-time or historical alert for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["ORDER", "RFQ", "SHIPMENT", "FINANCE", "SYSTEM"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "link": { "type": "string", "description": "Internal URL to the related resource." },
        "isRead": { "type": "boolean", "default": false },
        "isArchived": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "priority", "title", "message"]
    },
    "SystemAnnouncement": {
      "title": "Platform Announcement",
      "description": "A global broadcast message from platform administrators.",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "targetRoles": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserBehaviorLog": {
      "title": "User Behavior Log",
      "description": "Granular interaction logs for AI recommendation training.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string", "enum": ["VIEW", "CLICK", "FAVORITE", "SEARCH"] },
        "entityType": { "type": "string", "enum": ["PRODUCT", "SUPPLIER", "RFQ"] },
        "entityId": { "type": "string" },
        "metadata": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AlgoConfig": {
      "title": "Algorithm Configuration",
      "description": "Global weight settings for the AI engine.",
      "type": "object",
      "properties": {
        "technicalWeight": { "type": "number" },
        "geoWeight": { "type": "number" },
        "behaviorWeight": { "type": "number" },
        "urgencyWeight": { "type": "number" },
        "lastUpdatedBy": { "type": "string" }
      }
    },
    "SupplierProfile": {
      "title": "Supplier Profile",
      "description": "Public business identity for a verified supplier in the directory.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "country": { "type": "string" },
        "yearsActive": { "type": "number" },
        "mineralsOffered": { "type": "array", "items": { "type": "string" } },
        "averageRating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "badges": { "type": "array", "items": { "type": "string" } }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Immutable record of administrative and system safety actions.",
      "type": "object",
      "properties": {
        "actorId": { "type": "string" },
        "actionCode": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "ipAddress": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "SecurityIncident": {
      "title": "Security Incident",
      "description": "Record of a detected or reported security threat.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["UNAUTHORIZED_ACCESS", "BRUTE_FORCE", "DATA_EXFILTRATION", "MFA_FAILURE"] },
        "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "status": { "type": "string", "enum": ["OPEN", "INVESTIGATING", "CONTAINED", "RESOLVED"] },
        "details": { "type": "string" },
        "affectedUserId": { "type": "string" },
        "ipAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserPermission": {
      "title": "Role-Based Permission",
      "description": "Mapping of roles to specific platform capability flags.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "ComplianceRecord": {
      "title": "Regulatory Compliance Record",
      "description": "Evidence of adherence to regional laws (GDPR, IT Rules, etc.).",
      "type": "object",
      "properties": {
        "region": { "type": "string" },
        "standard": { "type": "string" },
        "status": { "type": "string", "enum": ["COMPLIANT", "NON_COMPLIANT", "AWAITING_AUDIT"] },
        "lastAuditDate": { "type": "string", "format": "date" },
        "nextAuditDue": { "type": "string", "format": "date" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/subscriptions/{subId}": { "schema": "#/backend/entities/UserSubscription", "description": "Active user plans." },
    "/ad_campaigns/{campId}": { "schema": "#/backend/entities/AdCampaign", "description": "Promotional records." },
    "/commissions/{commId}": { "schema": "#/backend/entities/CommissionRecord", "description": "Trade fee ledger." },
    "/notifications/{noteId}": { "schema": "#/backend/entities/Notification", "description": "Individual user alerts." },
    "/announcements/{annoId}": { "schema": "#/backend/entities/SystemAnnouncement", "description": "Platform-wide broadcasts." },
    "/user_behavior_logs/{logId}": { "schema": "#/backend/entities/UserBehaviorLog", "description": "Event stream for AI engine." },
    "/audit_logs/{logId}": { "schema": "#/backend/entities/AuditLog", "description": "System integrity records." },
    "/security_incidents/{incidentId}": { "schema": "#/backend/entities/SecurityIncident", "description": "Threat monitoring ledger." },
    "/role_permissions/{roleId}": { "schema": "#/backend/entities/UserPermission", "description": "Access control matrix." },
    "/compliance_vault/{recordId}": { "schema": "#/backend/entities/ComplianceRecord", "description": "Regulatory evidence records." },
    "/dashboard_configs/{configId}": { "schema": "#/backend/entities/DashboardConfig", "description": "UI layout settings." },
    "/system_metrics/{metricId}": { "schema": "#/backend/entities/SystemMetric", "description": "Performance telemetry logs." },
    "/async_jobs/{jobId}": { "schema": "#/backend/entities/AsyncJob", "description": "Background process queue records." }
  }
}
