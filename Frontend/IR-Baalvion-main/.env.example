# IR-Baalvion environment template. Copy to .env.local for development.
# NEVER commit a real .env.local. Production values are injected at deploy time.

# ----------------------------------------------------------------------------
# Auth backend selection
# ----------------------------------------------------------------------------
# Path the auth client talks to. In production this MUST point at the real
# central gateway BFF (e.g. /auth-bff). Leave the local value ONLY in dev.
NEXT_PUBLIC_AUTH_BFF_PATH=/auth-bff

# ----------------------------------------------------------------------------
# LOCAL (dev/standalone) auth backend — DEV ONLY, fail-closed in production
# ----------------------------------------------------------------------------
# The /api/auth-local routes are PERMANENTLY DISABLED when NODE_ENV=production.
# To use them in local dev you must opt in explicitly:
IR_LOCAL_AUTH_ENABLED=false

# Seed accounts for the local backend, as a JSON array. Server-only (not shipped
# to the browser). Set this ONLY in your own .env.local — never commit real values.
# Example (replace with throwaway dev passwords):
# IR_LOCAL_SEED_USERS=[{"id":"usr_admin","email":"dev-admin@example.test","password":"CHANGE_ME","name":"Dev Admin","role":"admin"}]
IR_LOCAL_SEED_USERS=

# Optional dev quick-login buttons in the login modal (JSON array). NEXT_PUBLIC_*
# is bundled into the client, so use throwaway dev credentials only and leave it
# unset in any shared/preview deployment.
# NEXT_PUBLIC_IR_DEV_QUICK_ACCOUNTS=[{"label":"Admin","email":"dev-admin@example.test","password":"CHANGE_ME"}]
NEXT_PUBLIC_IR_DEV_QUICK_ACCOUNTS=

# Refresh cookie name (must match the gateway).
NEXT_PUBLIC_REFRESH_COOKIE_NAME=baalvion_refresh
