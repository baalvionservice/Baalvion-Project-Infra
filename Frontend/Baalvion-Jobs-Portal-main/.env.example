# Environment variables for the Baalvion Jobs Portal

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# The base URL for your backend API
NEXT_PUBLIC_API_URL=http://localhost:9002

# Use mock data for development
NEXT_PUBLIC_USE_MOCK=true

# Google Cloud Service Account Key (JSON string or file path)
# For production: Set as environment variable
# For local development: Create service-account.json file
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# Google Indexing API Secret
GOOGLE_INDEXING_SECRET=your_secret_string_here
