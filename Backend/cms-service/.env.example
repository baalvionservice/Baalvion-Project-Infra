# CMS Service — Port 3011
PORT=3011
NODE_ENV=development

# Shared JWT secret (verify-only — auth-service issues tokens)
JWT_ACCESS_SECRET=replace-with-strong-access-secret

# PostgreSQL (shared Baalvion DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173

# Cache TTLs (seconds)
CACHE_CONTENT_TTL=300
CACHE_PUBLIC_TTL=600
CACHE_TAXONOMY_TTL=1800

# Rate limiting
RATE_LIMIT_IP_MAX=200

# Downstream services
MEDIA_SERVICE_URL=http://localhost:3012
NOTIFICATION_SERVICE_URL=http://localhost:3013
