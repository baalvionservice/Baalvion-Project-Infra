# ── Server ──────────────────────────────────────────────────────────────────
PORT=4100
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3030,http://localhost:3035,http://localhost:3026,http://localhost:9002

# ── PostgreSQL (Prisma) — uses the shared Dockerized Postgres, schema "os" ──
DATABASE_URL=postgresql://baalvion:baalvion_dev_pass@localhost:5432/baalvion_db?schema=os

# ── Redis (realtime fan-out) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Keycloak (SSO IdP) ──────────────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8088
KEYCLOAK_REALM=baalvion
KEYCLOAK_ISSUER=http://localhost:8088/realms/baalvion
KEYCLOAK_JWKS_URI=http://localhost:8088/realms/baalvion/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=baalvion-os

# ── Object storage (S3 / MinIO) ─────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=baalvion
S3_ACCESS_KEY=baalvion
S3_SECRET_KEY=baalvion_dev_pass
S3_FORCE_PATH_STYLE=true
PRESIGN_EXPIRY_SECONDS=900
