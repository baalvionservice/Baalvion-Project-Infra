    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.17.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
