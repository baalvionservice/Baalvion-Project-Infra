{
  "name": "baalvion-os",
  "version": "0.1.0",
  "private": true,
  "description": "Baalvion OS — unified NestJS backend (replaces Firebase)",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prebuild": "prisma generate",
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
