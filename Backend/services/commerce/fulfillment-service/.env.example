JWT_ACCESS_SECRET=replace-with-strong-access-secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
PORT=3015
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173
RATE_LIMIT_IP_MAX=200
# RBAC service (commerce-rbac PEP)
RBAC_BASE_URL=http://localhost:3055
RBAC_API_PREFIX=/v1
RBAC_TIMEOUT_MS=4000
RBAC_FAIL_MODE=closed
RBAC_BREAKGLASS_SUPERADMIN=true
RBAC_INTERNAL_API_KEY=
# RBAC cache TTLs
CACHE_RBAC_EFFECTIVE_TTL=30
CACHE_RBAC_SCOPE_TTL=300
