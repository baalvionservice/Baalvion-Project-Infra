# Environment
NODE_ENV=development
PORT=3014

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion
DB_USER=postgres
DB_PASSWORD=postgres
DB_LOGGING=false
DB_SYNC=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true

# Queue Workers
QUEUE_WORKERS=true

# Auth (JWT) — RS256 verification (REQUIRED). authMiddleware now verifies real signatures
# (the prior accept-any-bearer mock is removed). Paste the platform RS256 public key (\n-escaped).
JWT_PUBLIC_KEY=
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_ISSUER=https://identity.baalvion.io
JWT_AUDIENCE=baalvion-api

# Service-to-service key for trusted callers (order-service posts payment journal entries).
# MUST match order-service's LEDGER_INTERNAL_KEY. Empty = only user bearer tokens accepted.
LEDGER_INTERNAL_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3025

# Observability
LOG_LEVEL=info
