JWT_ACCESS_SECRET=replace-with-strong-access-secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
PORT=3014
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173
RATE_LIMIT_IP_MAX=200
# Reservation/lock TTL in minutes (how long a checkout hold survives without confirm/release)
INVENTORY_LOCK_TTL_MINUTES=15
# Internal service key for the reservation `confirm` endpoint (commits stock without payment, so it
# must be INTERNAL-ONLY). Must match order-service's INVENTORY_INTERNAL_KEY. Empty = dev fallback to
# the ops_manager RBAC chain (never anonymous-open). RECOMMENDED in production.
INVENTORY_INTERNAL_KEY=
