NODE_ENV=development
PORT=3012

DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Canonical RS256 verification (One True Verifier via @baalvion/auth-node).
# JWT_PUBLIC_KEY is REQUIRED at boot. Either paste the PEM (\n-escaped) or set JWKS_URI.
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
# JWKS_URI=

CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173

RATE_LIMIT_IP_MAX=200

CACHE_STORE_TTL=300
CACHE_PRODUCT_TTL=300
CACHE_CATEGORY_TTL=1800
CACHE_COLLECTION_TTL=600
CACHE_RBAC_EFFECTIVE_TTL=30
CACHE_RBAC_SCOPE_TTL=300

# RBAC service (source of truth for admin hierarchy + store-team roles).
RBAC_BASE_URL=http://localhost:3055
RBAC_API_PREFIX=/v1
RBAC_TIMEOUT_MS=4000
# closed = deny on RBAC outage (secure default); open = degrade
RBAC_FAIL_MODE=closed
# honor super_admin JWT claim if RBAC is unreachable (avoids platform-owner lockout)
RBAC_BREAKGLASS_SUPERADMIN=true
# optional system-context service key; must equal rbac-service INTERNAL_API_KEY. Empty = disabled
RBAC_INTERNAL_API_KEY=

# Anonymous storefront promo-code preview rate limit (requests/min/IP). Tighter than the global
# read limit because code-probing is a brute-force vector.
STOREFRONT_DISCOUNT_RL_MAX=8

# Seed/attach imagery. scripts/seedAmarise.js uses a dev placeholder (picsum) by default; point
# SEED_MEDIA_BASE_URL at a CDN of real licensed photos (<product-slug>-1.<ext>) to drop them in
# without a code change, or use scripts/attachProductMedia.js with a per-product URL manifest.
SEED_MEDIA_BASE_URL=
SEED_MEDIA_EXT=jpg

# Product media storage. local = filesystem (/uploads, dev default); minio/s3 = object storage.
MEDIA_DRIVER=local
MEDIA_MAX_BYTES=26214400
MEDIA_THUMB_SIZE=400
# Base URL used to build local media URLs (MEDIA_DRIVER=local).
COMMERCE_PUBLIC_URL=http://localhost:3012
# Object storage (MEDIA_DRIVER=minio|s3):
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=
S3_BUCKET=commerce-media
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Live FX feed (per-market pricing) ──────────────────────────────────────────
# Storefront prices are authored in USD and converted per market (config/markets.js). By default
# the conversion uses the STATIC FX_USD_<CCY> rates below. Turning on the live feed overrides those
# from a cached external USD-base snapshot; if the feed is down/stale/disabled, every conversion
# GRACEFULLY falls back to the static rate, so pricing never fails.
# Master switch. false (default) = static rates only (no network calls, byte-identical legacy math).
FX_LIVE_FEED=false
# USD-base FX provider. Default is KEYLESS (open.er-api.com). For a keyed provider set FX_API_URL
# to its USD-base endpoint and FX_API_KEY (appended as access_key). e.g. exchangerate.host.
FX_API_URL=https://open.er-api.com/v6/latest/USD
FX_API_KEY=
# Cached-snapshot TTL (seconds). A snapshot older than this is treated as stale → static fallback.
FX_CACHE_TTL=3600
# Background refresh cadence (ms). Keep below FX_CACHE_TTL so the cache never expires under reads.
FX_REFRESH_INTERVAL_MS=1800000
# Upstream fetch timeout (ms) — a hung feed never blocks the refresh job.
FX_FETCH_TIMEOUT_MS=5000
# Static USD→CCY fallback rates (1 USD = <rate> CCY). Used when the live feed is off/unavailable.
FX_USD_USD=1
FX_USD_GBP=0.79
FX_USD_AED=3.67
FX_USD_INR=83.3
FX_USD_SGD=1.35
