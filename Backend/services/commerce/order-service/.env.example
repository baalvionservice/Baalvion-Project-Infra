NODE_ENV=development
PORT=3013

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

# Redis (cache + BullMQ reconciliation worker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Canonical RS256 verification (REQUIRED at boot via @baalvion/auth-node).
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173
RATE_LIMIT_IP_MAX=200

# Payment provider. REQUIRED in production — set to a real provider (stripe|razorpay|paypal) with its
# keys. The default 'mock' is NON-PRODUCTION and THROWS in production unless ALLOW_MOCK_PAYMENTS=true
# (never set that in prod). Leaving this unset in production lets the server boot but fail at the first
# real payment. Smoke-test a full intent→confirm→capture before launch.
PAYMENT_PROVIDER=mock
# ALLOW_MOCK_PAYMENTS=false

# Provider payment-webhook signing secret. Verifies the HMAC-SHA256 (over the raw body) on
# POST /api/v1/orders/webhooks/payments — the provider-initiated async failure/cancellation hook
# that drives an order to failed/voided. EMPTY = webhooks are REJECTED (fail-closed). Set in
# production to the gateway's webhook secret; the X-Payment-Signature header must match.
PAYMENT_WEBHOOK_SECRET=
CACHE_ORDER_TTL=120
CACHE_CUSTOMER_TTL=300
CACHE_CART_TTL=1800

# Guest-cart session signing. Empty = guest carts disabled (fail-closed). RECOMMENDED in production.
CART_SESSION_SECRET=

# RBAC (single source of truth for store-team authorization)
RBAC_BASE_URL=http://localhost:3055
RBAC_API_PREFIX=/v1
RBAC_FAIL_MODE=closed

# Double-entry ledger (ledger-service). LEDGER_INTERNAL_KEY must match ledger-service's value.
# Empty = ledger posting + reconciliation are DISABLED (fail-open). RECOMMENDED in production.
LEDGER_BASE_URL=http://localhost:3014
LEDGER_API_PREFIX=/v1
LEDGER_INTERNAL_KEY=
LEDGER_TIMEOUT_MS=4000

# Scheduled reconciliation sweep (BullMQ). Requires the ledger configured above.
RECONCILE_ENABLED=true
RECONCILE_CRON=0 * * * *
RECONCILE_AUTO_BACKFILL=false
RECONCILE_LOOKBACK_DAYS=7

# Ops alerting → notification-service (reconciliation drift / ledger unreachable).
# INTERNAL_SERVICE_SECRET must match notification-service. Set an ops recipient to deliver alerts.
NOTIFICATION_BASE_URL=http://localhost:3031
NOTIFICATION_API_PREFIX=/v1
INTERNAL_SERVICE_SECRET=
OPS_ALERT_USER_ID=
OPS_ALERT_EMAIL=
