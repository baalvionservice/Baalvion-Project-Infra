# Environment
NODE_ENV=development
PORT=3015

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion
DB_USER=postgres
DB_PASSWORD=postgres
DB_LOGGING=false
DB_SYNC=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_ENABLED=true

# Queue Workers
QUEUE_WORKERS=true

# Auth (JWT — legacy interbank routes only)
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_ISSUER=https://identity.baalvion.io
JWT_AUDIENCE=baalvion-api

# ── @baalvion/sdk platform wiring (gateway-checkout vertical) ──
SERVICE_VERSION=1.0.0
# Shared service-to-service secret. REQUIRED in production (the service refuses to
# start with the dev default) — it guards the gateway create/read API via
# sdk.internalAuth AND authenticates to the CMS vault. Must match the CMS value.
INTERNAL_SERVICE_SECRET=baalvion-internal-dev-secret
# CMS Integrations & Keys hub — the SDK config-resolver target (provider + keys).
CMS_BASE_URL=http://localhost:3018/api/v1
# Domain event transport. Platform backbone = Redis Streams (baalvion:events),
# consumed by notification-service + audit-service. redis = real delivery; noop = log-only.
# Options: redis | nats | kafka | noop. Requires REDIS_* when 'redis'.
EVENT_TRANSPORT=redis
# Set false to skip the legacy interbank SQL migrations (gateway uses sync / 002).
RUN_MIGRATIONS=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3025

# Payment Limits
DAILY_LIMIT=1000000
TX_MAX_LIMIT=500000
TX_MIN_LIMIT=100

# Fee Configuration
FEE_PERCENTAGE=0.01
FEE_FLAT=50
VAT_RATE=0.05

# Idempotency
IDEMPOTENCY_TTL=86400

# Observability
LOG_LEVEL=info
