# ─────────────────────────────────────────────────────────────────────────────
# law-service environment template. Copy to `.env` for local dev.
# In production, prefer SECRETS_FILE (a mounted JSON secret) over plaintext .env.
# Never commit a real .env — secrets validation refuses placeholder values in prod.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3015
SERVICE_NAME=law-service

# ── Database (Postgres, schema `legal`) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=baalvion_dev_pass

# ── Auth (canonical RS256 verify-only — public key from the auth-service) ─────
# Paste the PEM with literal \n between lines, or mount via SECRETS_FILE.
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
# Optional JWKS endpoint (overrides static key when set)
BAALVION_JWKS_URI=
AUTH_SERVICE_URL=http://localhost:3001

# Mounted secrets file (Docker/K8s secret, AWS SM CSI driver, Vault Agent, …).
# Keys here override .env. e.g. SECRETS_FILE=/run/secrets/law.json
SECRETS_FILE=

# ── CORS / public URLs ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:9002,http://localhost:3000
APP_PUBLIC_URL=http://localhost:9002

# Platform-admin bootstrap allowlist (comma-separated emails)
LAW_ADMIN_EMAILS=infra.baalvion@gmail.com

# ── Object storage (MinIO / S3) for document uploads ─────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=law-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ── Redis (subscription-billing worker, websocket fan-out, rate-limit) ───────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Transactional email (SMTP; dev → Mailpit on :1025, no auth) ──────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Law Elite Network <no-reply@lawelitenetwork.com>"
# Set to "true" only when SMTP is configured; otherwise emails are logged, not sent.
MAIL_ENABLED=false

# ── Payments: Razorpay (DEFERRED to production — leave blank for simulated) ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Platform commission taken from each settled payment (percent)
PLATFORM_FEE_PERCENT=15

# ── Video consultations (env-gated provider; blank → placeholder rooms) ──────
# Supported: daily (Daily.co REST). Leave blank to disable real rooms.
VIDEO_PROVIDER=
DAILY_API_KEY=
DAILY_DOMAIN=

# ── Subscription billing worker ──────────────────────────────────────────────
BILLING_WORKER_ENABLED=true
# How often (minutes) the worker scans for due renewals
BILLING_INTERVAL_MINUTES=60

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_IP_MAX=120
