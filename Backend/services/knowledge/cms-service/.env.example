# CMS Service — Port 3018
PORT=3018
NODE_ENV=development
SERVICE_VERSION=1.0.0

# JWT verification (RS256 — auth-service issues tokens via @baalvion/auth-node).
# PEM public key (escape newlines as \n on a single line, or provide a JWKS URI).
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
# BAALVION_JWKS_URI=http://localhost:3001/.well-known/jwks.json

# PostgreSQL (shared Baalvion DB; cms owns the `cms` schema)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:5173

# Cache TTLs (seconds)
CACHE_CONTENT_TTL=300
CACHE_PUBLIC_TTL=600
CACHE_TAXONOMY_TTL=1800

# Rate limiting
RATE_LIMIT_IP_MAX=200

# Downstream services
MEDIA_SERVICE_URL=http://localhost:3012
NOTIFICATION_SERVICE_URL=http://localhost:3013

# ── @baalvion/sdk platform wiring ──
# Shared service-to-service secret. REQUIRED in non-development (the service
# refuses to start with the dev default outside NODE_ENV=development) — it guards
# the decrypted-keys resolver. CMS still stores tenant provider keys encrypted in
# its own vault; this is the inter-service auth secret, not a provider key.
INTERNAL_SERVICE_SECRET=baalvion-internal-dev-secret
# Self CMS hub base (the SDK config-resolver target). Defaults to the local port.
CMS_BASE_URL=http://localhost:3018/api/v1
# Domain event transport. The platform backbone is Redis Streams (baalvion:events),
# consumed by notification-service + audit-service. redis = real delivery; noop = log-only.
# Options: redis | nats | kafka | noop. Requires REDIS_* above when 'redis'.
EVENT_TRANSPORT=redis
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
