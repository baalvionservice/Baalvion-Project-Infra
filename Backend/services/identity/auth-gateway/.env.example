# auth-gateway (BFF / cookie gateway + trust boundary) — env template. Copy to .env (gitignored).
NODE_ENV=development
PORT=3026

# auth-service = single identity authority (RS256 issuer + JWKS)
AUTH_SERVICE_URL=http://localhost:3001/v1/auth
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform

# CORS must enumerate frontend origins (credentials:true forbids '*')
CORS_ORIGINS=http://localhost:3030,http://localhost:5173,http://localhost:8080

# Enforcement: hybrid (also inject server-side Bearer for legacy backends) | strict (signed gateway headers only)
BFF_ENFORCEMENT_MODE=hybrid

# REQUIRED (fail-closed): HMAC secret the gateway signs identity headers with; backends verify via gatewayTrust()
GATEWAY_SIGNING_SECRET=

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Cookie strategy
COOKIE_ACCESS_NAME=access_token
COOKIE_REFRESH_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.baalvion.com
COOKIE_ACCESS_MAX_AGE=900
COOKIE_REFRESH_MAX_AGE=604800

# /api/* proxy targets (override per env)
# SVC_MINING=http://localhost:3003
# SVC_DASHBOARD=http://localhost:3009
# SVC_ORDERS=http://localhost:3013
