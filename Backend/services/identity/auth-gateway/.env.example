NODE_ENV=development
PORT=3099
AUTH_SERVICE_URL=http://localhost:3001/v1/auth
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
# Browser origins allowed through the gateway. In production add the real frontend
# origin(s), comma-separated, e.g. https://controlthemarket.com.
CORS_ORIGINS=http://localhost:3034,http://localhost:3030,http://localhost:5173,https://controlthemarket.com
BFF_ENFORCEMENT_MODE=strict
# HMAC secret the gateway signs trusted identity headers with. MUST be a real >=32-char secret in
# production — the service fails closed on boot if this is missing or left at the dev placeholder.
GATEWAY_SIGNING_SECRET=<set-in-secret-manager>
# Internal-only endpoint shared secret. MUST be set in production.
INTERNAL_SERVICE_SECRET=<set-in-secret-manager>
REDIS_HOST=localhost
REDIS_PORT=6379
COOKIE_ACCESS_NAME=baalvion_access
COOKIE_REFRESH_NAME=baalvion_refresh
CSRF_COOKIE_NAME=csrf_token
COOKIE_SAMESITE=lax

# Phase 6E-6.6 — burn-in observation mode (observation only, no enforcement change)
BURN_IN_MODE=true

# Phase 7 — multi-region identity mesh + geo-fence
REGION=local
WORKLOAD_ID=auth-gateway
GEO_ENFORCEMENT=log
ENVELOPE_TTL_SECONDS=30

# Finance & Treasury sprint (2026-06-11) — financial-services-java suite is running locally on
# HIGH ports (13xxx) because the standard 3014-3039 ports are occupied by other platform services.
# These override routes/proxy.js TARGETS/FINANCE defaults so /finance-bff/* reaches the Java suite.
SVC_LEDGER=http://localhost:13014
SVC_PAYMENT=http://localhost:13015
SVC_ACCOUNT=http://localhost:13016
SVC_ESCROW=http://localhost:13017
SVC_SETTLEMENT=http://localhost:13018
SVC_FX=http://localhost:13038
SVC_WALLET=http://localhost:13039
SVC_INVOICE=http://localhost:13021
SVC_TRADE_FINANCE=http://localhost:13036
SVC_CREDIT=http://localhost:13037

# CTM (community/ecosystem) service runs on :3017 (NOT :3011 — that is the CMS service).
SVC_CTM=http://localhost:3017
