# ── rbac-service ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3055
API_BASE_URL=http://localhost:3055
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:3030

# ── Database (shared baalvion_db, isolated `rbac` schema) ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=
DB_SCHEMA=rbac
# Used by `pnpm migrate` (psql):
DATABASE_URL=postgres://baalvion:@localhost:5432/baalvion_db

# ── Canonical token verification (RS256 via @baalvion/auth-node) ────────────────
# In production, set JWT_PUBLIC_KEY to the auth-service public PEM so tokens verify.
# JWT_ACCESS_SECRET is only a DEV HS256 fallback when no RSA key is present.
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_PUBLIC_KEY=
JWT_ACCESS_SECRET=dev-insecure-rbac-secret

# ── Service-to-service PDP calls (optional) ─────────────────────────────────────
# When set, a PEP (other backend) may call POST /v1/authorize with header
# `X-Internal-Key: <this value>` instead of forwarding a user token.
INTERNAL_API_KEY=

LOG_LEVEL=debug
