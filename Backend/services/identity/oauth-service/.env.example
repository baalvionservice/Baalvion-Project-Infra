PORT=3023
NODE_ENV=development

# Shared PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT RS256 keys (shared with auth-service)
JWT_PRIVATE_KEY_PATH=
JWT_PRIVATE_KEY_B64=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY_PATH=
JWT_PUBLIC_KEY_B64=
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion

# OAuth2 settings
AUTH_CODE_TTL=600
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_REFRESH_TOKEN_TTL=2592000
OAUTH_BASE_URL=http://localhost:3023
OAUTH_SCOPES=openid profile email offline_access

# Auth UI URL for login redirect
AUTH_UI_URL=http://localhost:3000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
