{
  "name": "auth-service",
  "version": "2.0.0",
  "description": "Baalvion Central Auth Microservice — SSO for all Baalvion products",
  "license": "ISC",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-keys": "node scripts/generateKeys.js",
    "migrate": "psql $DATABASE_URL -f migrations/001_auth_schema.sql && psql $DATABASE_URL -f migrations/002_add_family_id.sql && psql $DATABASE_URL -f migrations/003_auth_audit_log.sql && psql $DATABASE_URL -f migrations/004_org_type.sql && psql $DATABASE_URL -v ON_ERROR_STOP=1 -f migrations/011_oauth_identity.sql && psql $DATABASE_URL -v ON_ERROR_STOP=1 -f migrations/009_rls_tenant_isolation.sql",
    "seed:gti": "node scripts/seedGtiOrganizations.js"
  },
  "dependencies": {
    "@baalvion/telemetry": "workspace:*",
    "@baalvion/graceful-shutdown": "workspace:*",
    "@baalvion/auth-node": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "speakeasy": "^2.0.0",
    "ua-parser-js": "^2.0.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}
