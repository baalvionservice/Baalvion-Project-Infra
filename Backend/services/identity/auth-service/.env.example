# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ── RSA Keys (RS256) ──────────────────────────────────────────────────────────
# Generate with: node scripts/generateKeys.js
# Leave blank in development — ephemeral keys will be generated on startup.
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# Alternative: base64-encoded PEM for containers
# JWT_PRIVATE_KEY_B64=
# JWT_PUBLIC_KEY_B64=

# ── JWT claims ────────────────────────────────────────────────────────────────
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-services
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=baalvion_refresh

# ── Legacy HS256 secrets (kept for backward compat, unused by new code) ───────
JWT_ACCESS_SECRET=replace-with-at-least-64-char-random-secret
JWT_REFRESH_SECRET=replace-with-different-64-char-random-secret

# ── Database (shared PostgreSQL) ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

# ── Redis (optional — service degrades gracefully without it) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_IP_MAX=20
RATE_LIMIT_EMAIL_MAX=10

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@baalvion.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Leave SMTP_HOST blank to log emails to console (dev mode)
