{
  "name": "tenant-service",
  "version": "1.0.0",
  "description": "Baalvion Tenant / White-Label Service — multi-tenant registry, per-app branding, custom-domain verification, and feature entitlements. Generalizes the proxy's white-label config platform-wide.",
  "license": "ISC",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "psql $DATABASE_URL -f migrations/001_tenant_schema.sql && psql $DATABASE_URL -v ON_ERROR_STOP=1 -f migrations/002_rls_tenant_isolation.sql",
    "test": "node --test",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@baalvion/telemetry": "workspace:*",
    "@baalvion/graceful-shutdown": "workspace:*",
    "express-rate-limit": "^7.5.0",
    "@baalvion/auth-node": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sequelize": "^6.37.8",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
