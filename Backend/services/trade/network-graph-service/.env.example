SERVICE_NAME=network-graph-service
NODE_ENV=development
PORT=3047

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password
NEO4J_DATABASE=neo4j
NEO4J_POOL=50

# ── Auth (RS256 only; gateway BFF) ───────────────────────────────────────────
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
GATEWAY_SIGNING_SECRET=dev_gateway_signing_secret
ISLAND_AUTH_MODE=hybrid

# ── Platform SDK / event bus ─────────────────────────────────────────────────
EVENT_TRANSPORT=redis
EVENT_STREAM=baalvion:events
EVENT_CONSUMER_GROUP=network-graph-service
REDIS_URL=redis://127.0.0.1:6379
CMS_BASE_URL=http://localhost:3011
INTERNAL_SERVICE_SECRET=dev_internal_secret

CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_IP_MAX=120
EVENT_CONSUMER=true
LOG_LEVEL=info
