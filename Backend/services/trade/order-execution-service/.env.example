SERVICE_NAME=order-execution-service
NODE_ENV=development
PORT=3052
DB_SCHEMA=oms

# ── PostgreSQL (R1: connect as the non-superuser app role) ───────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion_app
DB_PASSWORD=
# Migrations only — privileged owner role:
MIGRATION_DB_USER=baalvion
MIGRATION_DB_PASSWORD=

# ── Auth (R2: RS256 only; gateway BFF trust boundary) ────────────────────────
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
GATEWAY_SIGNING_SECRET=dev_gateway_signing_secret
ISLAND_AUTH_MODE=hybrid

# ── Finance webhook (Java → Node, HMAC-SHA256) ───────────────────────────────
FINANCE_WEBHOOK_SECRET=dev_finance_webhook_secret_change_me_min32

# ── Platform SDK / event bus (Redis Streams baalvion:events) ─────────────────
EVENT_TRANSPORT=redis
EVENT_STREAM=baalvion:events
EVENT_CONSUMER_GROUP=order-execution-service
REDIS_URL=redis://127.0.0.1:6379
CMS_BASE_URL=http://localhost:3011
INTERNAL_SERVICE_SECRET=dev_internal_secret

# ── Toggles ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_IP_MAX=120
OUTBOX_PUBLISHER=true
EVENT_CONSUMER=true
LOG_LEVEL=info
