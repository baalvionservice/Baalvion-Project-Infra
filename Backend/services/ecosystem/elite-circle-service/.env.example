PORT=3051
NODE_ENV=development

# ── PostgreSQL (shared baalvion_db, dedicated `elite_circle` schema) ──────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=baalvion_dev_pass
DB_SCHEMA=elite_circle

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-strong-secret-min-32-chars
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL_DAYS=30

# ── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:8080,http://localhost:3000
RATE_LIMIT_IP_MAX=300
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── File uploads (replaces Supabase Storage `elite-proofs` bucket) ────────────
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3051

# ── AI assistant (replaces ai-chat edge fn). OpenAI-compatible chat completions.
AI_API_KEY=
AI_BASE_URL=https://ai.gateway.lovable.dev/v1
AI_MODEL=google/gemini-2.5-flash
