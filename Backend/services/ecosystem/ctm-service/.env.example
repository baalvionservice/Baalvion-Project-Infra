PORT=3017
NODE_ENV=development
CORS_ORIGINS=http://localhost:3034,http://localhost:3025,http://localhost:3000,http://localhost:3030,http://localhost:4000

# JWT — shared with all services
JWT_ACCESS_SECRET=<set-in-secret-manager>

# Canonical RS256 verification (shared with auth-service on :3001).
# appConfig.js requires JWT_PUBLIC_KEY — without it the service refuses to boot.
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_PUBLIC_KEY=<set-in-secret-manager>

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=<set-in-secret-manager>

# Rate limiting
RATE_LIMIT_IP_MAX=120

# ── Phase 2 external integrations ───────────────────────────────────────────────
# Webhooks are fully live with NO config (per-webhook secret is generated by the service).
# Everything below is OPTIONAL: each integration stays dormant until its keys are set.

# GitHub repo metadata: public repos work WITHOUT a token (rate-limited). Set for higher limits / private repos.
GITHUB_TOKEN=<set-in-secret-manager>

# Payments (provider-agnostic). Set ONE provider's keys to go live; otherwise checkout records as 'manual'.
PAYMENT_PROVIDER=
# Stripe:   PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=<set-in-secret-manager>
STRIPE_WEBHOOK_SECRET=<set-in-secret-manager>
# Razorpay: PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=<set-in-secret-manager>
RAZORPAY_KEY_SECRET=<set-in-secret-manager>
RAZORPAY_WEBHOOK_SECRET=<set-in-secret-manager>

# Code-execution sandbox for auto-graded test cases (Judge0 or compatible).
JUDGE0_URL=
JUDGE0_KEY=<set-in-secret-manager>
JUDGE0_HOST=
