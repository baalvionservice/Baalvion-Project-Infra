PORT=3017
NODE_ENV=development
# Browser origins allowed to call this service. In production set this to the real
# frontend origin(s), comma-separated, e.g. https://controlthemarket.com.
CORS_ORIGINS=http://localhost:3034,http://localhost:3025,http://localhost:3000,http://localhost:3030,https://controlthemarket.com

# JWT — shared with all services
JWT_ACCESS_SECRET=<set-in-secret-manager>

# Canonical RS256 verification (shared with auth-service on :3001).
# appConfig.js requires JWT_PUBLIC_KEY — without it the service refuses to boot.
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWT_PUBLIC_KEY=<set-in-secret-manager>

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=<set-in-secret-manager>

# Rate limiting
RATE_LIMIT_IP_MAX=120

# ── Phase 2 external integrations ───────────────────────────────────────────────
# Webhooks are fully live with NO config (per-webhook secret is generated by the service).
# Everything below is OPTIONAL: each integration stays dormant until its keys are set.

# GitHub repo metadata: public repos work WITHOUT a token (rate-limited). Set for higher limits / private repos.
GITHUB_TOKEN=<set-in-secret-manager>

# Payments. PRODUCTION keys live in the CENTRAL CMS vault (admin panel → CMS → Websites →
# "control-the-market" → Integrations & Keys → Stripe/Razorpay). ctm-service resolves them from the
# vault per request — paste a key in the console and checkout uses it within ~60s, NO redeploy and
# NO secret in this file. Both Stripe and Razorpay can be configured at once (buyer picks at checkout).
#
# Vault wiring (REQUIRED in production so ctm-service can read the admin-panel keys):
CMS_BASE_URL=http://cms-service:3011/api/v1
INTERNAL_SERVICE_SECRET=<shared-platform-internal-secret>
PAYMENT_SITE_SLUG=control-the-market
#
# Optional default provider when a checkout request omits one (else the first configured is used).
PAYMENT_PROVIDER=
# Post-checkout redirect URLs (fallbacks if the caller doesn't pass success/cancel URLs).
PAYMENT_SUCCESS_URL=https://controlthemarket.com/company/billing?paid=1
PAYMENT_CANCEL_URL=https://controlthemarket.com/company/billing?canceled=1
#
# ── Local-dev ONLY fallback ── if the CMS vault is unreachable, ctm-service falls back to these
# env keys. Leave blank in production (the vault is the source of truth). Never commit real keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Code-execution sandbox for auto-graded test cases (Judge0 or compatible).
JUDGE0_URL=
JUDGE0_KEY=<set-in-secret-manager>
JUDGE0_HOST=
