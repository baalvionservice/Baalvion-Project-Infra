PORT=3050
NODE_ENV=development

# ── PostgreSQL (shared baalvion_db, dedicated `insiders` schema) ──────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=baalvion_dev_pass
DB_SCHEMA=insiders

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-strong-secret-min-32-chars
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL_DAYS=30

# ── Security ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
RATE_LIMIT_IP_MAX=300
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── File uploads (replaces Supabase Storage `elite-proofs` bucket) ────────────
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3050

# ── AI assistant (replaces ai-chat edge fn). OpenAI-compatible chat completions.
# Works with OpenAI, Anthropic-compatible gateways, Lovable AI gateway, etc.
AI_API_KEY=
AI_BASE_URL=https://ai.gateway.lovable.dev/v1
AI_MODEL=google/gemini-2.5-flash

# ── Membership tiers (USD) + upgrade proration window ─────────────────────────
TIER_FOUNDER=299
TIER_INVESTOR_PARTNER=499
UPGRADE_GRACE_DAYS=5

# ── Payment gateways (leave blank = demo mode; fill to go live) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://secure.payu.in/_payment
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
CRYPTO_API_KEY=
CRYPTO_WEBHOOK_SECRET=
CRYPTO_BASE_URL=https://commerce.coinbase.com
