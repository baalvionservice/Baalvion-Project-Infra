# ── search-service ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3036
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:8080

# OpenSearch (consumed by @baalvion/search). Bring one up for dev with:
#   docker run -d --name baalvion-opensearch -p 9200:9200 \
#     -e discovery.type=single-node -e DISABLE_SECURITY_PLUGIN=true \
#     -e OPENSEARCH_JAVA_OPTS="-Xms512m -Xmx512m" opensearchproject/opensearch:2
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=
OPENSEARCH_PASS=

# Canonical token verification (RS256 via @baalvion/auth-node). JWT_ACCESS_SECRET is
# only the dev HS256 fallback when no RSA public key is present.
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_PUBLIC_KEY=
JWT_ACCESS_SECRET=dev-insecure-search-secret

# Service-to-service indexing: producers send `X-Internal-Key: <this>` to POST /v1/index/...
INTERNAL_API_KEY=

LOG_LEVEL=debug
