# ── audit-service ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3032
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:8080

# Database (shared baalvion_db, isolated `audit` schema)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=
DB_SCHEMA=audit
DATABASE_URL=postgres://baalvion:@localhost:5432/baalvion_db

# Redis (event-bus consumer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auto-capture every platform event into the audit log
AUDIT_CONSUME_EVENTS=true
EVENT_BUS_STREAM=baalvion:events

# Canonical token verification (RS256 via @baalvion/auth-node). JWT_ACCESS_SECRET is
# only the dev HS256 fallback when no RSA public key is present.
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_PUBLIC_KEY=
JWT_ACCESS_SECRET=dev-insecure-audit-secret

# Service-to-service writes: PEPs send `X-Internal-Key: <this>` to POST /v1/audit
INTERNAL_API_KEY=

LOG_LEVEL=debug
