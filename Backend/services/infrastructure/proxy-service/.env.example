PORT=4000
API_BASE_URL=http://localhost:4000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=baalvion
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ── JWT (RS256) — generate with: node scripts/generateKeys.js ──────────────────
# Production MUST set RS256 keys. JWT_ALLOW_HS256_FALLBACK is only for cut-over.
JWT_ACTIVE_KID=baalvion-key-1
JWT_PRIVATE_KEY=                       # PEM (PKCS8) or path; \n-escaped if inline
JWT_PUBLIC_KEYS=                       # {"kid":"-----BEGIN PUBLIC KEY-----\n..."}
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_ALLOW_HS256_FALLBACK=false         # true only during HS256→RS256 migration
JWT_KEYS_DIR=./config/keys
# Legacy HS256 secret — retained only for the fallback verification window:
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=baalvion_refresh
WEBHOOK_SHARED_SECRET=replace-with-shared-webhook-secret

# ── Session / API-key tuning ───────────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=10
MEMBERSHIP_CACHE_TTL=30
API_KEY_PREFIX=bns_

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=120
RATE_LIMIT_USER_MAX=240
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
REDIS_URL=redis://127.0.0.1:6379

# ── Social login (Google / GitHub) — see docs/OAUTH-SOCIAL-LOGIN.md ────────────
# Public origin the provider redirects the browser back to (must serve the SPA AND
# /auth-bff/*). Locally this is the Vite dev server. In prod set it to the public host.
OAUTH_PUBLIC_BASE_URL=http://localhost:8080
# Where the post-login redirect lands (the SPA). Usually the same as OAUTH_PUBLIC_BASE_URL.
APP_URL=http://localhost:8080
# Register the OAuth apps and paste the credentials here. Authorized redirect URI to
# register in BOTH consoles: ${OAUTH_PUBLIC_BASE_URL}/auth-bff/oauth/<provider>/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
BCRYPT_ROUNDS=12

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=proxy-backend
