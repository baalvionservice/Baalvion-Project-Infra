    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "opossum": "^8.1.4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
