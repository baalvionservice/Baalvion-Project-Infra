NODE_ENV=development
PORT=3041
CORS_ORIGINS=http://localhost:3000,http://localhost:3030,http://localhost:8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=CHANGE_ME
DB_SCHEMA=reports
DATABASE_URL=postgres://baalvion:CHANGE_ME@localhost:5432/baalvion_db

# Default read-only report datasource (point at a read replica in prod). Extra
# datasources: REPORT_DSN_<KEY>=postgres://...
REPORT_DEFAULT_DSN=postgres://baalvion:CHANGE_ME@localhost:5432/baalvion_db
REPORT_MAX_ROWS=100000
REPORT_STATEMENT_TIMEOUT_MS=30000
REPORT_SCHEDULER=true
REPORT_SCHEDULER_TICK_MS=60000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
EVENT_BUS_STREAM=baalvion:events

# No JWT_PUBLIC_KEY → HS256 dev fallback using the shared dev secret (tokens verify locally)
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-platform
JWT_ACCESS_SECRET=CHANGE_ME

INTERNAL_API_KEY=CHANGE_ME
LOG_LEVEL=info
