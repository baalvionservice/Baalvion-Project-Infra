PORT=3031
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email — Resend (primary)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email — SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Email settings
EMAIL_FROM=noreply@baalvion.com
EMAIL_FROM_NAME=Baalvion
EMAIL_REPLY_TO=support@baalvion.com
EMAIL_RATE_LIMIT_PER_HOUR=10

# ── SMS (Twilio) — leave blank for dev "log" provider ──────────────────────────
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=
SMS_RATE_LIMIT_PER_HOUR=10

# ── Push — FCM and/or Web Push (both OPTIONAL, lazy-loaded). Blank → "log" ──────
# FCM is a push transport only (NOT Firebase auth). Provide ONE of the service-account forms.
PUSH_PROVIDER=auto
FCM_SERVICE_ACCOUNT=
FCM_SERVICE_ACCOUNT_B64=
FCM_SERVICE_ACCOUNT_PATH=
FCM_PROJECT_ID=
# Web Push (VAPID) — Firebase-free browser push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@baalvion.com
PUSH_RATE_LIMIT_PER_HOUR=60

# ── In-app / realtime (published to Redis pub/sub for realtime-service) ─────────
REALTIME_CHANNEL_PREFIX=baalvion:realtime:user
INAPP_INBOX_MAX=100
INAPP_INBOX_TTL=2592000

# JWT (verify-only)
JWT_PUBLIC_KEY_PATH=
JWT_PUBLIC_KEY_B64=
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion

# Service auth
INTERNAL_SERVICE_SECRET=change-me

# Worker concurrency
EMAIL_WORKER_CONCURRENCY=5
WEBHOOK_WORKER_CONCURRENCY=10
SMS_WORKER_CONCURRENCY=5
PUSH_WORKER_CONCURRENCY=10
NOTIFICATION_WORKER_CONCURRENCY=10

# App links used inside emails
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3030

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9467

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3030
