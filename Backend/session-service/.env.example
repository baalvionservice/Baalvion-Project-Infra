PORT=3022
NODE_ENV=development

# Shared PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=baalvion_db
DB_USER=baalvion
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT verification (same keys as auth-service, verify-only)
JWT_PUBLIC_KEY_PATH=
JWT_PUBLIC_KEY_B64=
JWT_PUBLIC_KEY=
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion

# Inter-service auth
INTERNAL_SERVICE_SECRET=change-me-strong-secret

# Risk thresholds
IMPOSSIBLE_TRAVEL_KMH=900
HIGH_RISK_SCORE=70

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
