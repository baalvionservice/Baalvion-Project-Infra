{
  "name": "@baalvion/events",
  "version": "1.0.0",
  "description": "Event contracts, publisher factory, Redis Stream integration",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import":  "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build":      "tsup",
    "dev":        "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean":      "rimraf dist"
  },
  "dependencies": {
    "@baalvion/types": "workspace:*",
    "uuid":            "^11.1.0"
  },
  "peerDependencies": {
    "nats":    "^2.28.0",
    "kafkajs": "^2.2.4"
  },
  "peerDependenciesMeta": {
    "nats":    { "optional": true },
    "kafkajs": { "optional": true }
  },
  "devDependencies": {
    "tsup":       "^8.3.0",
    "typescript": "^5.7.2",
    "rimraf":     "^6.0.1"
  }
}
