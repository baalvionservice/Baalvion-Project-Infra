{
  "name": "@baalvion/sdk",
  "version": "1.0.0",
  "description": "Baalvion Platform SDK v1 — unified service communication layer for CMS config resolution, service auth, event bus, logging, telemetry, and trace context. Composes internal @baalvion/* modules. Zero external runtime dependencies.",
  "private": true,

  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },

  "files": [
    "dist"
  ],

  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },

  "dependencies": {
    "@baalvion/types": "workspace:*"
  },

  "peerDependencies": {
    "@baalvion/events": "workspace:*",
    "@baalvion/logger": "workspace:*",
    "@baalvion/telemetry": "workspace:*",
    "@baalvion/service-kit": "workspace:*",
    "@baalvion/cache": "workspace:*",
    "express": "^4 || ^5"
  },

  "peerDependenciesMeta": {
    "@baalvion/events": { "optional": true },
    "@baalvion/logger": { "optional": true },
    "@baalvion/telemetry": { "optional": true },
    "@baalvion/service-kit": { "optional": true },
    "@baalvion/cache": { "optional": true },
    "express": { "optional": true }
  },

  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "rimraf": "^6.0.1",
    "@types/node": "^22.10.0"
  }
}