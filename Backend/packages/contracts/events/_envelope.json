{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "baalvion://events/_envelope.json",
  "title": "PlatformEventEnvelope",
  "description": "Common envelope for every event on the bus. Payload is constrained per event type.",
  "type": "object",
  "required": ["id", "type", "payload", "timestamp", "traceId"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "type": { "type": "string" },
    "orgId": { "type": ["string", "null"] },
    "userId": { "type": ["string", "null"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "traceId": { "type": "string" },
    "payload": { "type": "object" }
  }
}
