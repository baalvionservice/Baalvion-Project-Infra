{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "baalvion://events/tenant.provisioned.v1.json",
  "title": "TenantProvisioned",
  "allOf": [{ "$ref": "baalvion://events/_envelope.json" }],
  "properties": {
    "type": { "const": "tenant.provisioned" },
    "payload": {
      "type": "object",
      "required": ["tenantId", "slug"],
      "additionalProperties": true,
      "properties": {
        "tenantId": { "type": "string" },
        "slug": { "type": "string" },
        "orgId": { "type": ["string", "null"] },
        "plan": { "type": "string" }
      }
    }
  }
}
