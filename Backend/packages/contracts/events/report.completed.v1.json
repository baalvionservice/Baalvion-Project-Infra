{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "baalvion://events/report.completed.v1.json",
  "title": "ReportCompleted",
  "allOf": [{ "$ref": "baalvion://events/_envelope.json" }],
  "properties": {
    "type": { "const": "report.completed" },
    "payload": {
      "type": "object",
      "required": ["reportId", "runId", "format", "rowCount"],
      "additionalProperties": true,
      "properties": {
        "reportId": { "type": "string" },
        "runId": { "type": "string" },
        "name": { "type": "string" },
        "orgId": { "type": ["string", "null"] },
        "format": { "type": "string" },
        "rowCount": { "type": "integer" },
        "byteSize": { "type": "integer" },
        "triggeredBy": { "type": ["string", "null"] }
      }
    }
  }
}
