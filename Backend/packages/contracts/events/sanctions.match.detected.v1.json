{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "baalvion://events/sanctions.match.detected.v1.json",
  "title": "SanctionsMatchDetected",
  "description": "Emitted by risk-service when a screening is not CLEAR (a potential or confirmed watchlist hit). Compliance/case-management consumers act on this.",
  "allOf": [{ "$ref": "baalvion://events/_envelope.json" }],
  "properties": {
    "type": { "const": "sanctions.match.detected" },
    "payload": {
      "type": "object",
      "required": ["screeningId", "tenantId", "status", "topScore", "hitCount"],
      "additionalProperties": true,
      "properties": {
        "screeningId": { "type": "string", "format": "uuid" },
        "tenantId": { "type": "string", "format": "uuid" },
        "status": { "type": "string", "enum": ["POTENTIAL_MATCH", "CONFIRMED_MATCH"] },
        "topScore": { "type": "number" },
        "hitCount": { "type": "integer" },
        "referenceType": { "type": ["string", "null"] },
        "referenceId": { "type": ["string", "null"] }
      }
    }
  }
}
