{
  "name": "@baalvion/middleware",
  "version": "1.0.0",
  "description": "Shared Express middleware: auth, CSRF, rate limiting, request context",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import":  "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build":      "tsup",
    "dev":        "tsup --watch",
    "type-check": "tsc --noEmit",
    "test":       "node --test test/",
    "clean":      "rimraf dist"
  },
  "dependencies": {
    "@baalvion/types":  "workspace:*",
    "@baalvion/errors": "workspace:*",
    "@baalvion/logger": "workspace:*",
    "@baalvion/rbac":   "workspace:*",
    "jsonwebtoken":     "^9.0.3",
    "uuid":             "^11.1.0"
  },
  "devDependencies": {
    "tsup":             "^8.3.0",
    "typescript":       "^5.7.2",
    "rimraf":           "^6.0.1",
    "@types/node":      "^22.0.0",
    "@types/express":   "^5.0.0",
    "@types/express-serve-static-core": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "express":          "^5.2.1"
  }
}
