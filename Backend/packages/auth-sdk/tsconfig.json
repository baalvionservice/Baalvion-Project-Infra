{
  "compilerOptions": {
    "target":          "ES2022",
    "lib":             ["ES2022", "DOM", "DOM.Iterable"],
    "module":          "ESNext",
    "moduleResolution":"Bundler",
    "jsx":             "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict":          true,
    "skipLibCheck":    true,
    "forceConsistentCasingInFileNames": true,
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true,
    "rootDir":         "src",
    "outDir":          "dist"
  },
  "include":  ["src"],
  "exclude":  ["dist", "node_modules"]
}
