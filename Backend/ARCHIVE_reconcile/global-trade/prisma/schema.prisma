// BAALVION SOVEREIGN OS: AUTHORITATIVE DATA FOUNDATION
// Standard: Institutional Multi-Tenant / Geopolitical Scale

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- IDENTITY & AUTHORITY DOMAIN ---

enum OrganizationType {
  BUYER
  SELLER
  BANK
  GOVERNMENT
  LOGISTICS_PROVIDER
}

model Organization {
  id                String           @id @default(uuid())
  tenantId          String           @unique
  name              String
  type              OrganizationType
  country           String
  trustScore        Int              @default(500)
  verificationLevel Int              @default(1)
  isIsolated        Boolean          @default(false)
  metadata          Json?            // Industry, TaxID, etc.
  
  users             User[]
  wallets           Wallet[]
  rfqs              RFQ[]
  shipments         Shipment[]
  
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([type, country])
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  name           String
  role           String       // RBAC Authority Node
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  lastLogin      DateTime?
  status         String       @default("ACTIVE")
  
  @@index([organizationId])
}

// --- TRADE EXECUTION DOMAIN ---

enum TradeStatus {
  DRAFT
  OPEN
  NEGOTIATION
  AWARDED
  FINALIZED
  LOCKED
  IN_TRANSIT
  DELIVERED
  SETTLED
  CANCELLED
}

model RFQ {
  id             String       @id @default(uuid())
  title          String
  category       String
  quantity       Float
  unit           String
  targetPrice    Decimal      @db.Decimal(18, 2)
  currency       String       @default("USD")
  status         TradeStatus  @default(OPEN)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  quotations     Quotation[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, category])
}

model Quotation {
  id             String       @id @default(uuid())
  rfqId          String
  rfq            RFQ          @relation(fields: [rfqId], references: [id])
  sellerId       String
  price          Decimal      @db.Decimal(18, 2)
  deliveryTime   String
  status         String       @default("PENDING")
  evaluationScore Int?
  
  createdAt      DateTime     @default(now())
}

model TradeDeal {
  id             String       @id @default(uuid())
  orderId        String?      @unique
  buyerId        String
  sellerId       String
  product        String
  price          Decimal      @db.Decimal(18, 2)
  quantity       Float
  status         TradeStatus
  version        Int          @default(1)
  
  @@index([buyerId, sellerId])
}

// --- FINANCIAL & SETTLEMENT DOMAIN ---

model Wallet {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  currency       String
  balance        Decimal      @db.Decimal(24, 2) @default(0)
  escrowLocked   Decimal      @db.Decimal(24, 2) @default(0)
  
  @@unique([organizationId, currency])
}

model EscrowMandate {
  id             String       @id @default(uuid())
  orderId        String       @unique
  amount         Decimal      @db.Decimal(18, 2)
  currency       String
  status         String       @default("LOCKED")
  releaseRule    String       @default("MILESTONE_VERIFIED")
  
  createdAt      DateTime     @default(now())
}

// --- LOGISTICS & MOVEMENT DOMAIN ---

model Shipment {
  id             String       @id @default(uuid())
  orderId        String       @unique
  carrierId      String
  origin         String
  destination    String
  status         TradeStatus
  currentLocation String?
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  milestones     Milestone[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Milestone {
  id             String       @id @default(uuid())
  shipmentId     String
  shipment       Shipment     @relation(fields: [shipmentId], references: [id])
  type           String
  status         String
  isVerified     Boolean      @default(false)
  evidenceHash   String?
  timestamp      DateTime     @default(now())
}

// --- COGNITION & AUDIT DOMAIN ---

model AIReasoningTrace {
  id             String       @id @default(uuid())
  missionId      String
  agentId        String
  thought        String       @db.Text
  actionTaken    String?
  confidence     Float
  metadata       Json?
  
  createdAt      DateTime     @default(now())

  @@index([missionId, agentId])
}

model GlobalAuditLedger {
  id             String       @id @default(uuid())
  eventType      String
  aggregateId    String
  actorId        String
  tenantId       String
  payload        Json
  signature      String       // Cryptographical non-repudiation
  
  timestamp      DateTime     @default(now())

  @@index([aggregateId, eventType])
}
