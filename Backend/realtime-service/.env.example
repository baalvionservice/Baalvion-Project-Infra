REALTIME_PORT=3040
PORT=3040
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# JWT — RS256 (preferred — issued by auth-service via JWKS)
JWT_ISSUER=baalvion-auth
JWT_AUDIENCE=baalvion-services

# Primary: JWKS endpoint (preferred — auto-rotates with auth-service)
JWKS_URI=http://localhost:3001/.well-known/jwks.json
JWKS_TTL_MS=300000

# Fallback: static RSA public key (used when JWKS endpoint is unreachable)
# Set ONE of these — raw PEM or base64-encoded PEM
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_B64=

# JWT — HS256 shared secret (used by proxy-backend, jobs-service, ctm-service, etc.)
# Set this to the same value as JWT_ACCESS_SECRET in auth-service
JWT_SECRET=

# Dev only — accepts ALL WebSocket connections without JWT verification
# NEVER set to true in production
JWT_BYPASS_AUTH=false

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3024,http://localhost:3025,http://localhost:3026,http://localhost:3027,http://localhost:3028,http://localhost:3029,http://localhost:3030,http://localhost:8080

# Service URLs (for health polling)
AUTH_SERVICE_URL=http://localhost:3001
ADMIN_SERVICE_URL=http://localhost:3021
SESSION_SERVICE_URL=http://localhost:3022
OAUTH_SERVICE_URL=http://localhost:3023
NOTIF_SERVICE_URL=http://localhost:3031

# Poll intervals (ms)
METRICS_INTERVAL=5000
HEALTH_INTERVAL=10000
EVENTS_INTERVAL=2000

# Rate limiting
WS_RATE_LIMIT_PER_MINUTE=60
WS_RATE_LIMIT_PER_SECOND=30
