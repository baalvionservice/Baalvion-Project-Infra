# Remote-state backend config for `terraform init -backend-config=backend.hcl`.
# Copy to `backend.hcl` (gitignored) and adjust. The bucket + DynamoDB lock table
# below MUST already exist before `terraform init` (chicken-and-egg) — bootstrap
# them once, out-of-band, with the snippet in README.md (§1).
bucket         = "baalvion-terraform-state"
key            = "baalvion/terraform.tfstate"
region         = "ap-south-1"
encrypt        = true
dynamodb_table = "baalvion-terraform-locks"

# Optional: a dedicated KMS key for state-at-rest (recommended for production).
# kms_key_id   = "arn:aws:kms:ap-south-1:<ACCOUNT_ID>:key/<KEY_ID>"
