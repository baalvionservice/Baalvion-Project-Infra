# Normalize line endings: auto-detect text, commit as LF.
* text=auto eol=lf

# Windows-only scripts keep CRLF.
*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Shell scripts must stay LF even on Windows checkouts.
*.sh    text eol=lf

# Treat lockfiles as generated (collapse diffs, still tracked).
pnpm-lock.yaml   linguist-generated=true
package-lock.json linguist-generated=true
yarn.lock        linguist-generated=true

# Documentation should not skew language stats.
docs/**          linguist-documentation
*.md             linguist-documentation

# Binary assets — never diffed or EOL-converted.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
*.gz    binary

# Exclude non-shipping files from source archives.
.github/        export-ignore
e2e/            export-ignore
docs/           export-ignore
*.test.ts       export-ignore
